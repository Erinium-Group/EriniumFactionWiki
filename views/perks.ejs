<%- include('partials/head', { pageTitle: 'Perks — EriniumFaction Wiki' }) %>
<style>
    /* ── Tier header ── */
    .tier-header {
      display: flex;
      align-items: center;
      gap: 14px;
      margin: 36px 0 18px;
    }
    .tier-header-line {
      flex: 1;
      height: 1px;
      background: var(--glass-border);
    }
    .tier-badge {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 6px 18px;
      border-radius: 100px;
      font-size: 0.8rem;
      font-weight: 800;
      letter-spacing: 0.05em;
      text-transform: uppercase;
      white-space: nowrap;
    }
    .tier-10 { background: rgba(46,204,113,0.15);  border: 1px solid rgba(46,204,113,0.35);  color: #2ECC71; }
    .tier-20 { background: rgba(52,152,219,0.15);  border: 1px solid rgba(52,152,219,0.35);  color: #3498DB; }
    .tier-30 { background: rgba(241,196,15,0.15);  border: 1px solid rgba(241,196,15,0.35);  color: #F1C40F; }
    .tier-40 { background: rgba(230,126,34,0.15);  border: 1px solid rgba(230,126,34,0.35);  color: #E67E22; }
    .tier-50 { background: rgba(231,76,60,0.15);   border: 1px solid rgba(231,76,60,0.35);   color: #E74C3C; animation: glow-pulse 2.5s ease-in-out infinite; }

    /* ── Perk cards grid ── */
    .perk-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
      gap: 16px;
      margin-bottom: 8px;
    }
    .perk-card {
      background: var(--glass-bg);
      backdrop-filter: var(--blur-glass);
      -webkit-backdrop-filter: var(--blur-glass);
      border: 1px solid var(--glass-border);
      border-radius: var(--radius-lg);
      padding: 20px 18px;
      position: relative;
      overflow: hidden;
      transition: transform var(--transition), box-shadow var(--transition);
      cursor: default;
    }
    .perk-card::before {
      content: '';
      position: absolute;
      top: 0; left: 10%; right: 10%;
      height: 1px;
      background: linear-gradient(90deg, transparent, rgba(255,255,255,0.16), transparent);
    }
    .perk-card:hover { transform: translateY(-3px); box-shadow: var(--shadow-md); }
    .perk-card-t10:hover { box-shadow: var(--shadow-md), 0 0 20px rgba(46,204,113,0.20); border-color: rgba(46,204,113,0.30); }
    .perk-card-t20:hover { box-shadow: var(--shadow-md), 0 0 20px rgba(52,152,219,0.20); border-color: rgba(52,152,219,0.30); }
    .perk-card-t30:hover { box-shadow: var(--shadow-md), 0 0 20px rgba(241,196,15,0.20); border-color: rgba(241,196,15,0.30); }
    .perk-card-t40:hover { box-shadow: var(--shadow-md), 0 0 20px rgba(230,126,34,0.20); border-color: rgba(230,126,34,0.30); }
    .perk-card-t50:hover { box-shadow: var(--shadow-md), 0 0 20px rgba(231,76,60,0.25);  border-color: rgba(231,76,60,0.35); }

    .perk-icon   { font-size: 1.8rem; margin-bottom: 10px; display: block; }
    .perk-name   { font-size: 1rem; font-weight: 800; letter-spacing: -0.01em; color: var(--text); margin-bottom: 6px; }
    .perk-desc   { font-size: 0.82rem; color: var(--text-muted); line-height: 1.55; }
    .perk-tag    {
      display: inline-flex;
      align-items: center;
      gap: 4px;
      padding: 2px 9px;
      border-radius: 100px;
      font-size: 0.65rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.06em;
      margin-top: 10px;
    }
    .tag-passif  { background: rgba(107,47,160,0.18); border: 1px solid rgba(107,47,160,0.35); color: var(--accent-secondary); }
    .tag-actif   { background: rgba(241,196,15,0.14); border: 1px solid rgba(241,196,15,0.32); color: #F1C40F; }
    .tag-aura    { background: rgba(46,204,113,0.14); border: 1px solid rgba(46,204,113,0.32); color: #2ECC71; }

    /* ── "1 parmi 3" indicator ── */
    .pick-notice {
      display: flex;
      align-items: center;
      gap: 8px;
      font-size: 0.75rem;
      color: var(--text-faint);
      margin-bottom: 14px;
    }
    .pick-notice::before {
      content: '';
      display: inline-block;
      width: 8px; height: 8px;
      border-radius: 50%;
      background: var(--accent-gold);
      flex-shrink: 0;
    }

    /* ── Hero override ── */
    .hero-perks {
      background: linear-gradient(135deg,
        rgba(107, 47, 160, 0.12) 0%,
        rgba(0, 229, 255, 0.06) 100%);
    }
  </style>
</head>
<body>

<div class="floating-particles" aria-hidden="true"></div>
<div class="sidebar-overlay" id="sidebarOverlay"></div>
<%- include('partials/sidebar', { currentPage: currentPage }) %>
