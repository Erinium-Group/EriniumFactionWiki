<%- include('partials/head', { pageTitle: 'Enchantements — EriniumFaction Wiki' }) %>
<style>
  /* ── Tier color tokens ── */
  :root {
    --tier-vanilla:   #A0A0B0; --tier-vanilla-rgb:   160,160,176;
    --tier-valterite: #4AE0E0; --tier-valterite-rgb: 74,224,224;
    --tier-aetherite: #9B59B6; --tier-aetherite-rgb: 155,89,182;
    --tier-erinium:   #FFD700; --tier-erinium-rgb:   255,215,0;
  }

  /* ── Hero ── */
  .hero-ench {
    background: linear-gradient(135deg,
      rgba(74,224,224,0.10) 0%,
      rgba(155,89,182,0.08) 40%,
      rgba(255,215,0,0.07) 80%,
      transparent 100%);
  }

  /* ── Section dividers ── */
  .section-divider {
    display: flex;
    align-items: center;
    gap: 12px;
    margin: 36px 0 20px;
  }
  .section-divider-line { flex: 1; height: 1px; background: var(--glass-border); }
  .section-divider-text {
    font-size: 0.68rem; font-weight: 800; text-transform: uppercase;
    letter-spacing: 0.12em; color: var(--text-faint); white-space: nowrap;
  }

  /* ── How it works steps ── */
  .how-steps {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 14px;
    margin: 20px 0;
  }
  .how-step {
    background: var(--glass-bg);
    border: 1px solid var(--glass-border);
    border-radius: var(--radius-lg);
    padding: 18px 16px;
    display: flex; flex-direction: column; align-items: center; text-align: center;
    gap: 10px;
    transition: transform var(--transition), box-shadow var(--transition);
  }
  .how-step:hover { transform: translateY(-3px); box-shadow: 0 6px 20px rgba(107,47,160,0.15); }
  .how-step-num {
    width: 36px; height: 36px; border-radius: 50%;
    background: linear-gradient(135deg, rgba(107,47,160,0.35), rgba(74,224,224,0.20));
    border: 1px solid rgba(107,47,160,0.40);
    display: flex; align-items: center; justify-content: center;
    font-size: 1rem; font-weight: 900; color: var(--accent-secondary);
    flex-shrink: 0;
  }
  .how-step-title { font-size: 0.88rem; font-weight: 800; color: var(--text); }
  .how-step-desc  { font-size: 0.78rem; color: var(--text-muted); line-height: 1.5; }

  /* ── Tier cards (4 bookshelf tiers) ── */
  .tier-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 16px;
    margin: 20px 0;
  }
  .tier-card {
    position: relative;
    background: var(--glass-bg);
    border: 1px solid var(--glass-border);
    border-radius: var(--radius-xl);
    padding: 22px 20px 18px;
    overflow: hidden;
    transition: transform var(--transition), box-shadow var(--transition);
  }
  .tier-card::before {
    content: '';
    position: absolute;
    top: 0; left: 8%; right: 8%;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(255,255,255,0.22), transparent);
  }
  .tier-card:hover { transform: translateY(-4px); }

  .tier-vanilla   { border-top: 3px solid var(--tier-vanilla);   background: linear-gradient(160deg, rgba(var(--tier-vanilla-rgb),0.07) 0%, var(--glass-bg) 55%); }
  .tier-valterite { border-top: 3px solid var(--tier-valterite); background: linear-gradient(160deg, rgba(var(--tier-valterite-rgb),0.08) 0%, var(--glass-bg) 55%); }
  .tier-aetherite { border-top: 3px solid var(--tier-aetherite); background: linear-gradient(160deg, rgba(var(--tier-aetherite-rgb),0.09) 0%, var(--glass-bg) 55%); }
  .tier-erinium   { border-top: 3px solid var(--tier-erinium);   background: linear-gradient(160deg, rgba(var(--tier-erinium-rgb),0.08) 0%, var(--glass-bg) 55%); animation: glow-pulse 4s ease infinite; }

  .tier-vanilla:hover   { box-shadow: 0 6px 24px rgba(var(--tier-vanilla-rgb),0.20);   }
  .tier-valterite:hover { box-shadow: 0 6px 24px rgba(var(--tier-valterite-rgb),0.22); }
  .tier-aetherite:hover { box-shadow: 0 6px 24px rgba(var(--tier-aetherite-rgb),0.25); }
  .tier-erinium:hover   { box-shadow: 0 6px 24px rgba(var(--tier-erinium-rgb),0.28);   }

  .tier-header {
    display: flex; align-items: center; gap: 14px; margin-bottom: 16px;
  }
  .tier-bookshelf-img {
    width: 48px; height: 48px; image-rendering: pixelated;
    border-radius: var(--radius-md);
    border: 1px solid var(--glass-border);
    flex-shrink: 0;
  }
  .tier-name {
    font-size: 1.1rem; font-weight: 900; letter-spacing: -0.02em;
  }
  .tier-vanilla   .tier-name { color: var(--tier-vanilla);   }
  .tier-valterite .tier-name { color: var(--tier-valterite); }
  .tier-aetherite .tier-name { color: var(--tier-aetherite); }
  .tier-erinium   .tier-name { color: var(--tier-erinium);   }

  .tier-subtitle { font-size: 0.72rem; color: var(--text-faint); font-weight: 600; text-transform: uppercase; letter-spacing: 0.07em; margin-top: 2px; }

  .tier-stat-row {
    display: flex; align-items: center; justify-content: space-between;
    padding: 7px 0; border-bottom: 1px solid var(--glass-border);
    font-size: 0.82rem;
  }
  .tier-stat-row:last-child { border-bottom: none; }
  .tier-stat-label { color: var(--text-faint); font-weight: 600; }
  .tier-stat-value { font-weight: 800; }
  .tier-vanilla   .tier-stat-value { color: var(--tier-vanilla);   }
  .tier-valterite .tier-stat-value { color: var(--tier-valterite); }
  .tier-aetherite .tier-stat-value { color: var(--tier-aetherite); }
  .tier-erinium   .tier-stat-value { color: var(--tier-erinium);   }

  /* XP cost pills */
  .xp-pills { display: flex; gap: 5px; flex-wrap: wrap; }
  .xp-pill {
    font-size: 0.7rem; font-weight: 800; padding: 2px 8px; border-radius: 100px;
    background: rgba(0,0,0,0.25); border: 1px solid rgba(255,255,255,0.10);
    color: var(--text-muted);
  }
  .tier-vanilla   .xp-pill { border-color: rgba(var(--tier-vanilla-rgb),0.30);   color: var(--tier-vanilla);   }
  .tier-valterite .xp-pill { border-color: rgba(var(--tier-valterite-rgb),0.30); color: var(--tier-valterite); }
  .tier-aetherite .xp-pill { border-color: rgba(var(--tier-aetherite-rgb),0.30); color: var(--tier-aetherite); }
  .tier-erinium   .xp-pill { border-color: rgba(var(--tier-erinium-rgb),0.30);   color: var(--tier-erinium);   }

  /* ── Vanilla boosted table ── */
  .boosted-table {
    width: 100%;
    border-collapse: collapse;
    margin: 16px 0;
    font-size: 0.84rem;
  }
  .boosted-table th, .boosted-table td {
    padding: 10px 14px;
    text-align: left;
    border-bottom: 1px solid var(--glass-border);
  }
  .boosted-table th {
    font-size: 0.68rem; font-weight: 800; text-transform: uppercase;
    letter-spacing: 0.08em; color: var(--text-faint); background: var(--glass-bg);
  }
  .boosted-table td { color: var(--text-muted); }
  .boosted-table td:first-child { font-weight: 700; color: var(--text); }
  .old-max { color: var(--text-faint); text-decoration: line-through; font-size: 0.78em; }
  .new-max { color: var(--tier-erinium); font-weight: 900; }
  .roman-badge {
    display: inline-block;
    padding: 1px 6px; border-radius: 4px;
    font-size: 0.72em; font-weight: 800;
    background: rgba(255,215,0,0.12);
    border: 1px solid rgba(255,215,0,0.30);
    color: var(--tier-erinium);
    margin-left: 2px;
  }

  /* ── Enchantment cards grid ── */
  .ench-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 14px;
    margin: 20px 0;
  }
  .ench-card {
    position: relative;
    background: var(--glass-bg);
    border: 1px solid var(--glass-border);
    border-radius: var(--radius-lg);
    padding: 16px 16px 14px;
    overflow: hidden;
    transition: transform var(--transition), box-shadow var(--transition), border-color var(--transition);
  }
  .ench-card::before {
    content: '';
    position: absolute;
    top: 0; left: 8%; right: 8%;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(255,255,255,0.18), transparent);
  }
  .ench-card:hover { transform: translateY(-3px); }

  /* Category colors */
  .ench-weapon  { border-left: 3px solid #E74C3C; }
  .ench-weapon:hover  { box-shadow: 0 4px 20px rgba(231,76,60,0.18);  border-color: rgba(231,76,60,0.45); border-left-color: #E74C3C; }
  .ench-armor   { border-left: 3px solid #3498DB; }
  .ench-armor:hover   { box-shadow: 0 4px 20px rgba(52,152,219,0.18); border-color: rgba(52,152,219,0.45); border-left-color: #3498DB; }
  .ench-bow     { border-left: 3px solid #2ECC71; }
  .ench-bow:hover     { box-shadow: 0 4px 20px rgba(46,204,113,0.18); border-color: rgba(46,204,113,0.42); border-left-color: #2ECC71; }
  .ench-tool    { border-left: 3px solid #F39C12; }
  .ench-tool:hover    { box-shadow: 0 4px 20px rgba(243,156,18,0.18); border-color: rgba(243,156,18,0.42); border-left-color: #F39C12; }

  .ench-card-header {
    display: flex; align-items: flex-start; justify-content: space-between;
    gap: 8px; margin-bottom: 10px;
  }
  .ench-name { font-size: 0.96rem; font-weight: 800; color: var(--text); }
  .ench-weapon  .ench-name { color: #E74C3C; }
  .ench-armor   .ench-name { color: #5DADE2; }
  .ench-bow     .ench-name { color: #2ECC71; }
  .ench-tool    .ench-name { color: #F39C12; }

  .ench-badges { display: flex; gap: 5px; flex-wrap: wrap; margin-top: 3px; }
  .ench-badge {
    font-size: 0.62rem; font-weight: 800; text-transform: uppercase;
    letter-spacing: 0.06em; padding: 2px 7px; border-radius: 100px;
  }
  .badge-maxlvl {
    background: rgba(255,215,0,0.12); border: 1px solid rgba(255,215,0,0.35); color: var(--tier-erinium);
  }
  .badge-tier-vanilla   { background: rgba(160,160,176,0.14); border: 1px solid rgba(160,160,176,0.35); color: var(--tier-vanilla); }
  .badge-tier-valterite { background: rgba(74,224,224,0.12);  border: 1px solid rgba(74,224,224,0.35);  color: var(--tier-valterite); }
  .badge-tier-aetherite { background: rgba(155,89,182,0.14);  border: 1px solid rgba(155,89,182,0.38);  color: var(--tier-aetherite); }
  .badge-tier-erinium   { background: rgba(255,215,0,0.12);   border: 1px solid rgba(255,215,0,0.38);   color: var(--tier-erinium); }

  .ench-effect {
    font-size: 0.80rem; color: var(--text-muted); line-height: 1.55;
    border-top: 1px solid var(--glass-border);
    padding-top: 9px; margin-top: 4px;
  }
  .ench-effect strong { color: var(--text); }

  /* ── Anvil tip block ── */
  .anvil-tip {
    display: flex; align-items: flex-start; gap: 16px;
    background: rgba(255,215,0,0.05);
    border: 1px solid rgba(255,215,0,0.25);
    border-radius: var(--radius-lg);
    padding: 18px 20px;
    margin: 20px 0;
  }
  .anvil-tip-icon { font-size: 2rem; flex-shrink: 0; }
  .anvil-tip-body { font-size: 0.85rem; color: var(--text-muted); line-height: 1.65; }
  .anvil-tip-body strong { color: var(--tier-erinium); }
</style>
</head>
<body>

<div class="floating-particles" aria-hidden="true"></div>
<div class="sidebar-overlay" id="sidebarOverlay"></div>
<%- include('partials/sidebar', { currentPage: currentPage }) %>
<%- include('partials/header') %>

<div class="floating-particles" aria-hidden="true">
  <span class="star" style="left:8%;top:12%;animation-delay:0s;animation-duration:3.8s;"></span>
  <span class="star" style="left:22%;top:6%;animation-delay:1.3s;animation-duration:4.2s;"></span>
  <span class="star" style="left:55%;top:18%;animation-delay:0.7s;animation-duration:3.5s;"></span>
  <span class="star" style="left:75%;top:10%;animation-delay:2.0s;animation-duration:4.8s;"></span>
  <span class="star" style="left:88%;top:28%;animation-delay:0.9s;animation-duration:3.2s;"></span>
  <span class="star" style="left:42%;top:62%;animation-delay:1.6s;animation-duration:4.0s;"></span>
  <span class="star" style="left:65%;top:74%;animation-delay:0.3s;animation-duration:5.0s;"></span>
  <span class="star" style="left:5%;top:80%;animation-delay:2.4s;animation-duration:3.7s;"></span>
  <span class="star" style="left:92%;top:60%;animation-delay:1.1s;animation-duration:4.4s;"></span>
</div>

<div class="page-wrapper">
  <main class="main" id="main-content">

    <!-- ─── Hero ─────────────────────────────────────────────── -->
    <section class="hero hero-ench" aria-labelledby="hero-title">
      <span class="hero-badge">📖 Enchantements</span>
      <h1 id="hero-title">Les Enchantements</h1>
      <p>Rends tes armes, armures et outils encore plus puissants grâce aux enchantements ! Il y a 4 tiers de bibliothèques, des enchantements vanilla boostés, et 40 enchantements custom rien que pour toi.</p>
      <div class="hero-meta">
        <div class="hero-meta-item">📚 <strong>4 tiers</strong> de bibliothèques</div>
        <div class="hero-meta-item">⬆️ <strong>11 vanilla</strong> boostés</div>
        <div class="hero-meta-item">✨ <strong>40 enchantements</strong> custom</div>
        <div class="hero-meta-item">🏆 <strong>Niveau 90</strong> maximum</div>
      </div>
    </section>

    <!-- ─── Content ───────────────────────────────────────────── -->
    <div class="content has-toc">
      <div class="content-body">

        <!-- Breadcrumb -->
        <nav class="breadcrumb" aria-label="Fil d'Ariane">
          <a href="/">Accueil</a>
          <span class="breadcrumb-sep" aria-hidden="true">›</span>
          <span class="breadcrumb-current">Enchantements</span>
        </nav>

        <!-- ══════════════════════════════════════════════════════
             COMMENT ÇA MARCHE
        ══════════════════════════════════════════════════════ -->
        <section aria-labelledby="section-how">
          <h2 id="section-how">Comment ça marche ?</h2>
          <p>Pour enchanter, tu utilises une <strong>table d'enchantement</strong> entourée de <strong>16 bibliothèques</strong>. Les bibliothèques doivent toutes être du <strong>même type</strong> — on ne peut pas mélanger ! Dispose-les en carré autour de la table (bordure 5×5, même hauteur).</p>

          <div class="how-steps">
            <div class="how-step">
              <div class="how-step-num">1</div>
              <div class="how-step-title">Place la table</div>
              <div class="how-step-desc">Pose ta table d'enchantement au milieu d'un espace 5×5.</div>
            </div>
            <div class="how-step">
              <div class="how-step-num">2</div>
              <div class="how-step-title">Entoure-la de 16 bibliothèques</div>
              <div class="how-step-desc">Toutes les cases du bord (16 blocs), toutes du <strong>même type</strong>. Pas de mélange !</div>
            </div>
            <div class="how-step">
              <div class="how-step-num">3</div>
              <div class="how-step-title">Choisis ton slot</div>
              <div class="how-step-desc">3 slots disponibles — plus c'est à droite, plus c'est puissant (et plus ça coûte d'XP).</div>
            </div>
            <div class="how-step">
              <div class="how-step-num">4</div>
              <div class="how-step-title">Paie avec du Lapis</div>
              <div class="how-step-desc">Chaque slot coûte 1, 2 ou 3 Lapis-Lazuli en plus de l'XP.</div>
            </div>
          </div>

          <div class="glass-card glass-card-accent accent-violet" style="margin-bottom:8px;">
            <p style="margin:0;font-size:0.88rem;">
              💡 <strong>Astuce :</strong> Si tu mélanges différents types de bibliothèques, la table prend seulement les bibliothèques <em>Vanilla</em> en compte. Mets toujours le même type pour profiter du meilleur tier !
            </p>
          </div>
        </section>

        <!-- ══════════════════════════════════════════════════════
             RECETTES DES BIBLIOTHÈQUES
        ══════════════════════════════════════════════════════ -->
        <section aria-labelledby="section-craft">
          <h2 id="section-craft">Comment fabriquer les bibliothèques ?</h2>
          <p>Chaque bibliothèque custom se fabrique dans une <strong>table de craft 3×3</strong>. Les ingrédients changent selon le tier — plus c'est puissant, plus c'est rare !</p>

          <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:20px;margin:24px 0;">

            <!-- ── Bibliothèque de Valterite ── -->
            <div style="background:var(--glass-bg);border:1px solid rgba(74,224,224,0.30);border-top:3px solid #4AE0E0;border-radius:var(--radius-xl);padding:20px;">
              <div style="font-size:1rem;font-weight:900;color:#4AE0E0;margin-bottom:4px;">Bibliothèque de Valterite</div>
              <div style="font-size:0.72rem;color:var(--text-faint);font-weight:600;text-transform:uppercase;letter-spacing:0.07em;margin-bottom:16px;">Tier 2 · Cyan</div>

              <!-- Grille de craft 3x3 -->
              <div style="display:grid;grid-template-columns:repeat(3,48px);grid-template-rows:repeat(3,48px);gap:3px;margin:0 auto 16px;width:fit-content;">
                <!-- Rangée 1 : V V V -->
                <div style="width:48px;height:48px;background:#0d1117;border:1px solid rgba(74,224,224,0.45);border-radius:6px;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:2px;">
                  <img src="/img/items/valterite_ingot.png" alt="Lingot de Valterite" style="width:32px;height:32px;image-rendering:pixelated;" />
                </div>
                <div style="width:48px;height:48px;background:#0d1117;border:1px solid rgba(74,224,224,0.45);border-radius:6px;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:2px;">
                  <img src="/img/items/valterite_ingot.png" alt="Lingot de Valterite" style="width:32px;height:32px;image-rendering:pixelated;" />
                </div>
                <div style="width:48px;height:48px;background:#0d1117;border:1px solid rgba(74,224,224,0.45);border-radius:6px;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:2px;">
                  <img src="/img/items/valterite_ingot.png" alt="Lingot de Valterite" style="width:32px;height:32px;image-rendering:pixelated;" />
                </div>
                <!-- Rangée 2 : B B B -->
                <div style="width:48px;height:48px;background:#0d1117;border:1px solid rgba(74,224,224,0.25);border-radius:6px;display:flex;flex-direction:column;align-items:center;justify-content:center;font-size:1.4rem;">📖</div>
                <div style="width:48px;height:48px;background:#0d1117;border:1px solid rgba(74,224,224,0.25);border-radius:6px;display:flex;flex-direction:column;align-items:center;justify-content:center;font-size:1.4rem;">📖</div>
                <div style="width:48px;height:48px;background:#0d1117;border:1px solid rgba(74,224,224,0.25);border-radius:6px;display:flex;flex-direction:column;align-items:center;justify-content:center;font-size:1.4rem;">📖</div>
                <!-- Rangée 3 : V V V -->
                <div style="width:48px;height:48px;background:#0d1117;border:1px solid rgba(74,224,224,0.45);border-radius:6px;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:2px;">
                  <img src="/img/items/valterite_ingot.png" alt="Lingot de Valterite" style="width:32px;height:32px;image-rendering:pixelated;" />
                </div>
                <div style="width:48px;height:48px;background:#0d1117;border:1px solid rgba(74,224,224,0.45);border-radius:6px;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:2px;">
                  <img src="/img/items/valterite_ingot.png" alt="Lingot de Valterite" style="width:32px;height:32px;image-rendering:pixelated;" />
                </div>
                <div style="width:48px;height:48px;background:#0d1117;border:1px solid rgba(74,224,224,0.45);border-radius:6px;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:2px;">
                  <img src="/img/items/valterite_ingot.png" alt="Lingot de Valterite" style="width:32px;height:32px;image-rendering:pixelated;" />
                </div>
              </div>

              <!-- Légende -->
              <div style="font-size:0.74rem;color:var(--text-faint);line-height:1.8;margin-bottom:14px;">
                <span style="color:#4AE0E0;font-weight:700;">V</span> = Lingot de Valterite &nbsp;·&nbsp; <span style="color:var(--text-muted);font-weight:700;">📖</span> = Livre
              </div>

              <!-- Résultat -->
              <div style="display:flex;align-items:center;gap:10px;background:rgba(74,224,224,0.06);border:1px solid rgba(74,224,224,0.20);border-radius:8px;padding:10px 12px;">
                <img src="/img/blocks/valterite_bookshelf_side.png" alt="Bibliothèque Valterite" style="width:36px;height:36px;image-rendering:pixelated;" />
                <div>
                  <div style="font-size:0.82rem;font-weight:800;color:#4AE0E0;">× 1 Bibliothèque de Valterite</div>
                  <div style="font-size:0.70rem;color:var(--text-faint);">Résultat du craft</div>
                </div>
              </div>
            </div>

            <!-- ── Bibliothèque d'Aetherite ── -->
            <div style="background:var(--glass-bg);border:1px solid rgba(155,89,182,0.30);border-top:3px solid #9B59B6;border-radius:var(--radius-xl);padding:20px;">
