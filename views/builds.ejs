<%- include('partials/head', { pageTitle: 'Builds — EriniumFaction Wiki' }) %>
<style>
    /* ── Build color tokens ── */
    :root {
      --berserker: #E74C3C; --berserker-rgb: 231,76,60;
      --tank:      #5B9BD5; --tank-rgb:      91,155,213;
      --assassin:  #2ECC71; --assassin-rgb:  46,204,113;
      --mage:      #9B59B6; --mage-rgb:      155,89,182;
      --paladin:   #F1C40F; --paladin-rgb:   241,196,15;
    }

    /* ── Hero override ── */
    .hero-builds {
      background: linear-gradient(135deg,
        rgba(155,89,182,0.12) 0%,
        rgba(231,76,60,0.07) 50%,
        transparent 100%);
    }

    /* ── Quick compare table ── */
    .compare-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
      gap: 14px;
      margin: 24px 0 36px;
    }
    .compare-card {
      background: var(--glass-bg);
      backdrop-filter: var(--blur-glass);
      -webkit-backdrop-filter: var(--blur-glass);
      border: 1px solid var(--glass-border);
      border-radius: var(--radius-lg);
      padding: 20px 16px;
      text-align: center;
      position: relative;
      overflow: hidden;
      cursor: pointer;
      text-decoration: none;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 6px;
      transition: transform var(--transition), box-shadow var(--transition);
    }
    .compare-card::before {
      content: '';
      position: absolute;
      top: 0; left: 10%; right: 10%;
      height: 1px;
      background: linear-gradient(90deg, transparent, rgba(255,255,255,0.18), transparent);
    }
    .compare-card:hover { transform: translateY(-4px); }
    .cc-berserker { border-top: 3px solid var(--berserker); background: linear-gradient(160deg, rgba(var(--berserker-rgb),0.08) 0%, var(--glass-bg) 60%); }
    .cc-berserker:hover { box-shadow: var(--shadow-md), 0 0 22px rgba(var(--berserker-rgb),0.20); }
    .cc-tank      { border-top: 3px solid var(--tank);      background: linear-gradient(160deg, rgba(var(--tank-rgb),0.08) 0%, var(--glass-bg) 60%); }
    .cc-tank:hover      { box-shadow: var(--shadow-md), 0 0 22px rgba(var(--tank-rgb),0.18); }
    .cc-assassin  { border-top: 3px solid var(--assassin);  background: linear-gradient(160deg, rgba(var(--assassin-rgb),0.07) 0%, var(--glass-bg) 60%); }
    .cc-assassin:hover  { box-shadow: var(--shadow-md), 0 0 22px rgba(var(--assassin-rgb),0.18); }
    .cc-mage      { border-top: 3px solid var(--mage);      background: linear-gradient(160deg, rgba(var(--mage-rgb),0.09) 0%, var(--glass-bg) 60%); }
    .cc-mage:hover      { box-shadow: var(--shadow-md), 0 0 22px rgba(var(--mage-rgb),0.22); }
    .cc-paladin   { border-top: 3px solid var(--paladin);   background: linear-gradient(160deg, rgba(var(--paladin-rgb),0.07) 0%, var(--glass-bg) 60%); }
    .cc-paladin:hover   { box-shadow: var(--shadow-md), 0 0 22px rgba(var(--paladin-rgb),0.18); }
    .cc-icon { font-size: 2rem; line-height: 1; }
    .cc-name { font-size: 1rem; font-weight: 800; }
    .cc-berserker .cc-name { color: var(--berserker); }
    .cc-tank      .cc-name { color: var(--tank); }
    .cc-assassin  .cc-name { color: var(--assassin); }
    .cc-mage      .cc-name { color: var(--mage); }
    .cc-paladin   .cc-name { color: var(--paladin); }
    .cc-tagline { font-size: 0.75rem; color: var(--text-faint); font-style: italic; }
    .cc-diff { font-size: 0.65rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.07em; margin-top: 4px; }
    .diff-easy   { color: #2ECC71; }
    .diff-medium { color: #F1C40F; }
    .diff-hard   { color: #E74C3C; }

    /* ── Build section card ── */
    .build-section {
      background: var(--glass-bg);
      backdrop-filter: var(--blur-glass);
      -webkit-backdrop-filter: var(--blur-glass);
      border: 1px solid var(--glass-border);
      border-radius: var(--radius-xl);
      padding: 32px 28px 24px;
      margin-bottom: 32px;
      position: relative;
      overflow: hidden;
      transition: border-color var(--transition), box-shadow var(--transition);
    }
    .build-section::before {
      content: '';
      position: absolute;
      top: 0; left: 8%; right: 8%;
      height: 1px;
      background: linear-gradient(90deg, transparent, rgba(255,255,255,0.20), transparent);
    }
    .bs-berserker { border-left: 4px solid var(--berserker); background: linear-gradient(160deg, rgba(var(--berserker-rgb),0.08) 0%, var(--glass-bg) 55%); }
    .bs-berserker:hover { box-shadow: var(--shadow-lg), 0 0 30px rgba(var(--berserker-rgb),0.18); border-color: rgba(var(--berserker-rgb),0.40); border-left-color: var(--berserker); }
    .bs-tank { border-left: 4px solid var(--tank); background: linear-gradient(160deg, rgba(var(--tank-rgb),0.08) 0%, var(--glass-bg) 55%); }
    .bs-tank:hover { box-shadow: var(--shadow-lg), 0 0 30px rgba(var(--tank-rgb),0.18); border-color: rgba(var(--tank-rgb),0.40); border-left-color: var(--tank); }
    .bs-assassin { border-left: 4px solid var(--assassin); background: linear-gradient(160deg, rgba(var(--assassin-rgb),0.07) 0%, var(--glass-bg) 55%); }
    .bs-assassin:hover { box-shadow: var(--shadow-lg), 0 0 30px rgba(var(--assassin-rgb),0.18); border-color: rgba(var(--assassin-rgb),0.38); border-left-color: var(--assassin); }
    .bs-mage { border-left: 4px solid var(--mage); background: linear-gradient(160deg, rgba(var(--mage-rgb),0.09) 0%, var(--glass-bg) 55%); }
    .bs-mage:hover { box-shadow: var(--shadow-lg), 0 0 30px rgba(var(--mage-rgb),0.22); border-color: rgba(var(--mage-rgb),0.42); border-left-color: var(--mage); }
    .bs-paladin { border-left: 4px solid var(--paladin); background: linear-gradient(160deg, rgba(var(--paladin-rgb),0.07) 0%, var(--glass-bg) 55%); }
    .bs-paladin:hover { box-shadow: var(--shadow-lg), 0 0 30px rgba(var(--paladin-rgb),0.18); border-color: rgba(var(--paladin-rgb),0.38); border-left-color: var(--paladin); }

    /* ── Build header ── */
    .build-header {
      display: flex;
      align-items: flex-start;
      gap: 16px;
      margin-bottom: 24px;
      padding-bottom: 18px;
      border-bottom: 1px solid var(--glass-border);
      flex-wrap: wrap;
    }
    .build-class-icon { font-size: 2.8rem; line-height: 1; flex-shrink: 0; }
    .build-title-block { flex: 1; min-width: 0; }
    .build-class-name  { font-size: 1.6rem; font-weight: 900; letter-spacing: -0.03em; color: var(--text); margin-bottom: 4px; }
    .bs-berserker .build-class-name { color: var(--berserker); }
    .bs-tank      .build-class-name { color: var(--tank); }
    .bs-assassin  .build-class-name { color: var(--assassin); }
    .bs-mage      .build-class-name { color: var(--mage); }
    .bs-paladin   .build-class-name { color: var(--paladin); }
    .build-class-tagline { font-size: 0.85rem; color: var(--text-muted); font-style: italic; margin-bottom: 10px; }
    .build-tags { display: flex; flex-wrap: wrap; gap: 6px; }
    .build-tag {
      font-size: 0.68rem; font-weight: 700; padding: 3px 10px;
      border-radius: 100px; background: rgba(255,255,255,0.06);
      border: 1px solid rgba(255,255,255,0.12); color: var(--text-muted);
    }
    .build-difficulty-badge {
      padding: 5px 14px; border-radius: 100px; font-size: 0.72rem;
      font-weight: 800; text-transform: uppercase; letter-spacing: 0.07em; flex-shrink: 0;
    }
    .difficulty-easy   { background: rgba(46,204,113,0.18); border: 1px solid rgba(46,204,113,0.40); color: #2ECC71; }
    .difficulty-medium { background: rgba(241,196,15,0.14); border: 1px solid rgba(241,196,15,0.38); color: #F1C40F; }
    .difficulty-hard   { background: rgba(231,76,60,0.15);  border: 1px solid rgba(231,76,60,0.38);  color: #E74C3C; }

    /* ── Build body ── */
    .build-body {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
      gap: 16px;
      margin-bottom: 20px;
    }
    .build-block {
      background: rgba(0,0,0,0.18);
      border: 1px solid var(--glass-border);
      border-radius: var(--radius-lg);
      padding: 16px;
    }
    .build-block-title {
      font-size: 0.75rem; font-weight: 800;
      text-transform: uppercase; letter-spacing: 0.08em;
      color: var(--text-faint); margin-bottom: 12px;
      display: flex; align-items: center; gap: 6px;
    }
    .build-block-line {
      font-size: 0.83rem; color: var(--text-muted);
      margin-bottom: 6px; display: flex; align-items: baseline; gap: 6px;
    }
    .build-block-line strong { color: var(--text); flex-shrink: 0; }

    /* ── Stat alloc bars ── */
    .stat-alloc-row  { display: flex; align-items: center; gap: 10px; margin-bottom: 8px; font-size: 0.83rem; }
    .stat-alloc-name { font-weight: 700; min-width: 88px; flex-shrink: 0; }
    .stat-alloc-bar  { flex: 1; height: 6px; background: rgba(255,255,255,0.06); border-radius: 3px; overflow: hidden; }
    .stat-alloc-fill { height: 100%; border-radius: 3px; }
    .stat-alloc-pts  { font-weight: 700; min-width: 32px; text-align: right; font-size: 0.78rem; }
    .saf-vigueur    { background: #E74C3C; } .saf-force    { background: #E67E22; }
    .saf-resistance { background: #5B9BD5; } .saf-agilite  { background: #2ECC71; }
    .saf-fortune    { background: #F1C40F; } .saf-arcane   { background: #9B59B6; }
    .san-vigueur    { color: #E74C3C; } .san-force    { color: #E67E22; }
    .san-resistance { color: #5B9BD5; } .san-agilite  { color: #2ECC71; }
    .san-fortune    { color: #F1C40F; } .san-arcane   { color: #9B59B6; }

    /* ── Gem pills ── */
    .gem-socket-row { display: flex; align-items: center; gap: 8px; margin-bottom: 7px; font-size: 0.82rem; color: var(--text-muted); }
    .gem-socket-piece { font-weight: 700; color: var(--text); min-width: 80px; flex-shrink: 0; }
    .gem-pill {
      display: inline-flex; align-items: center; gap: 4px;
      padding: 2px 9px; border-radius: 100px; font-size: 0.7rem; font-weight: 700; margin-right: 2px;
    }
    .gem-ruby      { background: rgba(231,76,60,0.18);  border: 1px solid rgba(231,76,60,0.40);  color: #E74C3C; }
    .gem-sapphire  { background: rgba(52,152,219,0.18); border: 1px solid rgba(52,152,219,0.40); color: #3498DB; }
    .gem-emerald   { background: rgba(46,204,113,0.16); border: 1px solid rgba(46,204,113,0.38); color: #2ECC71; }
    .gem-amethyst  { background: rgba(155,89,182,0.18); border: 1px solid rgba(155,89,182,0.40); color: #9B59B6; }
    .gem-topaz     { background: rgba(241,196,15,0.16); border: 1px solid rgba(241,196,15,0.38); color: #F1C40F; }
    .gem-onyx      { background: rgba(44,62,80,0.55);   border: 1px solid rgba(127,140,141,0.45); color: #95A5A6; }

    /* ── Perk selector ── */
    .perk-sel-list { display: flex; flex-direction: column; gap: 8px; }
    .perk-sel-item {
      display: flex; align-items: flex-start; gap: 10px; padding: 10px 12px;
      border-radius: var(--radius-md); background: rgba(0,0,0,0.15);
      border: 1px solid var(--glass-border); font-size: 0.82rem;
    }
    .perk-sel-tier {
      width: 28px; height: 28px; border-radius: 50%;
      background: rgba(107,47,160,0.20); border: 1px solid rgba(107,47,160,0.35);
      font-size: 0.65rem; font-weight: 800; color: var(--accent-secondary);
      display: flex; align-items: center; justify-content: center; flex-shrink: 0;
    }
    .perk-sel-name { font-weight: 700; color: var(--text); margin-bottom: 2px; }
    .perk-sel-desc { color: var(--text-muted); font-size: 0.78rem; line-height: 1.5; }

    /* ── Spell loadout ── */
    .spell-loadout { display: flex; flex-direction: column; gap: 8px; }
    .spell-slot-row {
      display: flex; align-items: center; gap: 10px; padding: 8px 10px;
      border-radius: var(--radius-md); background: rgba(0,0,0,0.15);
      border: 1px solid var(--glass-border);
    }
    .spell-slot-num   { font-size: 0.68rem; font-weight: 800; color: var(--text-faint); width: 18px; flex-shrink: 0; }
    .spell-slot-icon  { width: 28px; height: 28px; image-rendering: pixelated; border-radius: 4px; flex-shrink: 0; }
    .spell-slot-name  { font-size: 0.84rem; font-weight: 700; color: var(--text); flex: 1; }
    .spell-slot-school {
      font-size: 0.68rem; font-weight: 700; text-transform: uppercase;
      letter-spacing: 0.06em; padding: 2px 7px; border-radius: 100px;
    }
    .school-fracture       { background: rgba(168,47,160,0.20); border: 1px solid rgba(168,47,160,0.40); color: #C84FC0; }
    .school-cristallisation { background: rgba(0,229,255,0.14);  border: 1px solid rgba(0,229,255,0.35);  color: #00E5FF; }
    .school-corruption     { background: rgba(46,204,113,0.15);  border: 1px solid rgba(46,204,113,0.35); color: #2ECC71; }
    .school-resonance      { background: rgba(242,196,15,0.14);  border: 1px solid rgba(242,196,15,0.32); color: #F2C40F; }

    /* ── Final stats ── */
    .final-stats { background: rgba(0,0,0,0.25); border: 1px solid var(--glass-border); border-radius: var(--radius-lg); padding: 18px 16px; margin-top: 8px; }
    .final-stats-title { font-size: 0.72rem; font-weight: 800; text-transform: uppercase; letter-spacing: 0.09em; color: var(--text-faint); margin-bottom: 12px; }
    .final-stats-grid  { display: grid; grid-template-columns: repeat(auto-fit, minmax(130px, 1fr)); gap: 10px; }
    .stat-bubble { background: var(--glass-bg); border: 1px solid var(--glass-border); border-radius: var(--radius-md); padding: 12px 10px; text-align: center; }
    .stat-bubble-value { font-size: 1.3rem; font-weight: 900; letter-spacing: -0.03em; line-height: 1; margin-bottom: 4px; }
    .stat-bubble-label { font-size: 0.62rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.07em; color: var(--text-faint); }

    /* ── Enchantment tier badges (reused from enchantments page) ── */
    .ench-badge {
      display: inline-block;
      font-size: 0.62rem; font-weight: 800; text-transform: uppercase;
      letter-spacing: 0.06em; padding: 2px 7px; border-radius: 100px;
    }
    .badge-maxlvl        { background: rgba(255,215,0,0.12);   border: 1px solid rgba(255,215,0,0.35);   color: #FFD700; }
    .badge-tier-vanilla  { background: rgba(160,160,176,0.14); border: 1px solid rgba(160,160,176,0.35); color: #A0A0B0; }
    .badge-tier-valterite{ background: rgba(74,224,224,0.12);  border: 1px solid rgba(74,224,224,0.35);  color: #4AE0E0; }
    .badge-tier-aetherite{ background: rgba(155,89,182,0.14);  border: 1px solid rgba(155,89,182,0.38);  color: #9B59B6; }
    .badge-tier-erinium  { background: rgba(255,215,0,0.12);   border: 1px solid rgba(255,215,0,0.38);   color: #FFD700; }

    /* ── Playstyle block ── */
    .playstyle-block {
      border-radius: var(--radius-lg); padding: 16px 20px; margin-top: 18px;
      background: linear-gradient(135deg, rgba(255,255,255,0.03), rgba(0,0,0,0.15));
      border: 1px solid var(--glass-border);
    }
    .bs-berserker .playstyle-block { border-left: 3px solid var(--berserker); }
    .bs-tank      .playstyle-block { border-left: 3px solid var(--tank); }
    .bs-assassin  .playstyle-block { border-left: 3px solid var(--assassin); }
    .bs-mage      .playstyle-block { border-left: 3px solid var(--mage); }
    .bs-paladin   .playstyle-block { border-left: 3px solid var(--paladin); }
    .playstyle-title { font-size: 0.72rem; font-weight: 800; text-transform: uppercase; letter-spacing: 0.09em; color: var(--text-faint); margin-bottom: 8px; }
    .playstyle-text  { font-size: 0.86rem; color: var(--text-muted); line-height: 1.7; }
    .sv-hp    { color: #E74C3C; } .sv-dmg  { color: #E67E22; }
    .sv-def   { color: #5B9BD5; } .sv-spd  { color: #2ECC71; }
    .sv-mana  { color: #9B59B6; } .sv-ls   { color: #C0392B; }
  </style>
</head>
<body>

<div class="floating-particles" aria-hidden="true"></div>
<div class="sidebar-overlay" id="sidebarOverlay"></div>
<%- include('partials/sidebar', { currentPage: currentPage }) %>
<%- include('partials/header') %>


<!-- ─── Floating Particles ──────────────────────────────────── -->
<div class="floating-particles" aria-hidden="true">
  <span class="star" style="left:10%;top:15%;animation-delay:0s;animation-duration:3.5s;"></span>
  <span class="star" style="left:25%;top:8%;animation-delay:1.2s;animation-duration:4.0s;"></span>
  <span class="star" style="left:50%;top:20%;animation-delay:0.6s;animation-duration:3.8s;"></span>
  <span class="star" style="left:72%;top:12%;animation-delay:2.1s;animation-duration:3.0s;"></span>
  <span class="star" style="left:86%;top:30%;animation-delay:0.9s;animation-duration:4.6s;"></span>
  <span class="star" style="left:40%;top:60%;animation-delay:1.8s;animation-duration:3.3s;"></span>
  <span class="star" style="left:63%;top:72%;animation-delay:0.4s;animation-duration:5.1s;"></span>
  <span class="star" style="left:6%;top:78%;animation-delay:2.5s;animation-duration:3.9s;"></span>
  <span class="star" style="left:90%;top:62%;animation-delay:1.4s;animation-duration:4.3s;"></span>
</div>

<!-- ─── Sidebar ──────────────────────────────────────────────── -->
  <!-- ─── Page Wrapper ──────────────────────────────────────────── -->
<div class="page-wrapper">
  <main class="main" id="main-content">

    <!-- ─── Hero ─────────────────────────────────────────────── -->
    <section class="hero hero-builds" aria-labelledby="hero-title">
      <span class="hero-badge">🏆 Builds</span>
      <h1 id="hero-title">Quelle classe vas-tu jouer ?</h1>
      <p>5 builds différents, 5 styles de jeu. Choisis celui qui te correspond et domine le PvP !</p>
      <div class="hero-meta">
        <div class="hero-meta-item">⚔️ <strong>PvP 1.8</strong> sans cooldown</div>
        <div class="hero-meta-item">📊 <strong>49 points</strong> à distribuer</div>
        <div class="hero-meta-item">💎 <strong>Gemmes</strong> Erinium Parfaites</div>
        <div class="hero-meta-item">🏆 <strong>5 archétypes</strong></div>
      </div>
    </section>

    <!-- ─── Content ───────────────────────────────────────────── -->
    <div class="content has-toc">
      <div class="content-body">

        <!-- Breadcrumb -->
        <nav class="breadcrumb" aria-label="Fil d'Ariane">
          <a href="/index">Accueil</a>
          <span class="breadcrumb-sep" aria-hidden="true">›</span>
          <span class="breadcrumb-current">Builds</span>
        </nav>

        <!-- ── Quelle classe choisir ? ── -->
        <section aria-labelledby="section-overview">
          <h2 id="section-overview">Quelle classe choisir ?</h2>
          <p>Clique sur un archétype pour accéder directement à son guide !</p>

          <div class="compare-grid">
            <a href="#build-berserker" class="compare-card cc-berserker">
              <span class="cc-icon">⚔️</span>
              <span class="cc-name">Berserker</span>
              <span class="cc-tagline">Frappe fort, vol de vie</span>
              <span class="cc-diff diff-easy">Facile</span>
            </a>
            <a href="#build-tank" class="compare-card cc-tank">
              <span class="cc-icon">🛡️</span>
              <span class="cc-name">Tank Cristallin</span>
              <span class="cc-tagline">Maximum de PV et défense</span>
              <span class="cc-diff diff-easy">Facile</span>
            </a>
            <a href="#build-assassin" class="compare-card cc-assassin">
              <span class="cc-icon">🗡️</span>
              <span class="cc-name">Assassin d'Ombre</span>
              <span class="cc-tagline">Vitesse, furtivité, burst</span>
              <span class="cc-diff diff-hard">Difficile</span>
            </a>
            <a href="#build-mage" class="compare-card cc-mage">
              <span class="cc-icon">🔮</span>
              <span class="cc-name">Mage Corrupteur</span>
              <span class="cc-tagline">Sorts, drain, contrôle</span>
              <span class="cc-diff diff-medium">Moyen</span>
            </a>
            <a href="#build-paladin" class="compare-card cc-paladin">
              <span class="cc-icon">✨</span>
              <span class="cc-name">Paladin de Soutien</span>
              <span class="cc-tagline">Soin, aura, faction</span>
              <span class="cc-diff diff-medium">Moyen</span>
            </a>
          </div>
        </section>

        <!-- ════════════════════════════════════════════════════
             BUILD 1 — BERSERKER
        ════════════════════════════════════════════════════ -->
        <section aria-labelledby="build-berserker">
          <h2 id="build-berserker">Build 1 — Berserker</h2>
          <div class="build-section bs-berserker">
            <div class="build-header">
              <span class="build-class-icon">⚔️</span>
              <div class="build-title-block">
                <div class="build-class-name">Berserker</div>
                <div class="build-class-tagline">« Plus tu frappes, plus tu te soignes. Et tu frappes beaucoup. »</div>
                <div class="build-tags">
                  <span class="build-tag">DPS Mêlée</span>
                  <span class="build-tag">Vol de vie</span>
                  <span class="build-tag">Épée Erinium</span>
                </div>
