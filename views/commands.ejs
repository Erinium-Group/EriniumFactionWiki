  <script>
  /* ── Commands filter script ────────────────────────────── */
  (function() {
    var input     = document.getElementById('cmdFilterInput');
    var countBadge = document.getElementById('cmdCountBadge');
    var TOTAL     = document.querySelectorAll('.data-table tbody tr').length;

    if (!input) return;

    countBadge.textContent = TOTAL + ' commandes';

    input.addEventListener('input', function() {
      var query = input.value.trim().toLowerCase();
      var visibleCount = 0;

      var tables = document.querySelectorAll('.data-table');

      tables.forEach(function(table) {
        var rows       = table.querySelectorAll('tbody tr');
        var noResults  = table.parentElement.querySelector('.cmd-no-results');
        var sectionVisible = 0;

        rows.forEach(function(row) {
          var text = row.textContent.toLowerCase();
          if (!query || text.indexOf(query) !== -1) {
            row.classList.remove('cmd-hidden');
            sectionVisible++;
            visibleCount++;
          } else {
            row.classList.add('cmd-hidden');
          }
        });

        if (noResults) {
          if (sectionVisible === 0 && query.length > 0) {
            noResults.classList.add('is-visible');
          } else {
            noResults.classList.remove('is-visible');
          }
        }
      });

      if (query.length === 0) {
        countBadge.textContent = TOTAL + ' commandes';
      } else {
        countBadge.textContent = visibleCount + ' résultat' + (visibleCount !== 1 ? 's' : '');
      }
    });
  })();
</script>

