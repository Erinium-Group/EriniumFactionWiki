<%- include('partials/head', { pageTitle: 'Magie — EriniumFaction Wiki' }) %>
<style>
    /* ── School overview cards ── */
    .school-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
      gap: 18px;
      margin: 24px 0;
    }
    .school-card {
      background: var(--glass-bg);
      backdrop-filter: var(--blur-glass);
      -webkit-backdrop-filter: var(--blur-glass);
      border-radius: var(--radius-lg);
      padding: 24px 18px;
      text-align: center;
      position: relative;
      overflow: hidden;
      transition: transform var(--transition), box-shadow var(--transition);
      cursor: default;
    }
    .school-card::before {
      content: '';
      position: absolute;
      top: 0; left: 15%; right: 15%;
      height: 1px;
      background: linear-gradient(90deg, transparent, rgba(255,255,255,0.20), transparent);
    }
    .school-card:hover { transform: translateY(-4px); }
    .school-card-fracture       { border: 1px solid rgba(168,47,160,0.30); }
    .school-card-fracture:hover { box-shadow: 0 8px 32px rgba(168,47,160,0.25); border-color: rgba(168,47,160,0.55); }
    .school-card-cristallisation       { border: 1px solid rgba(0,229,255,0.22); }
    .school-card-cristallisation:hover { box-shadow: 0 8px 32px rgba(0,229,255,0.18); border-color: rgba(0,229,255,0.45); }
    .school-card-corruption       { border: 1px solid rgba(46,204,113,0.22); }
    .school-card-corruption:hover { box-shadow: 0 8px 32px rgba(46,204,113,0.18); border-color: rgba(46,204,113,0.45); }
    .school-card-resonance       { border: 1px solid rgba(242,196,15,0.22); }
    .school-card-resonance:hover { box-shadow: 0 8px 32px rgba(242,196,15,0.18); border-color: rgba(242,196,15,0.45); }

    .school-emoji { font-size: 2.4rem; margin-bottom: 12px; display: block; }
    .school-name  { font-size: 1.05rem; font-weight: 800; letter-spacing: -0.01em; margin-bottom: 6px; }
    .school-name-fracture       { color: #C84FC0; }
    .school-name-cristallisation { color: #00E5FF; }
    .school-name-corruption     { color: #2ECC71; }
    .school-name-resonance      { color: #F2C40F; }
    .school-tagline { font-size: 0.77rem; color: var(--text-muted); line-height: 1.5; }
    .school-count   { font-size: 0.7rem; font-weight: 700; color: var(--text-faint); margin-top: 8px; text-transform: uppercase; letter-spacing: 0.06em; }

    /* ── Mana info blocks ── */
    .mana-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(150px, 1fr));
      gap: 14px;
      margin: 18px 0;
    }
    .mana-block {
      background: var(--glass-bg);
      border: 1px solid var(--glass-border);
      border-radius: var(--radius-md);
      padding: 14px 12px;
      text-align: center;
    }
    .mana-block-value {
      font-size: 1.6rem;
      font-weight: 900;
      letter-spacing: -0.03em;
      color: var(--accent-secondary);
      line-height: 1;
      margin-bottom: 4px;
    }
    .mana-block-label {
      font-size: 0.7rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.06em;
      color: var(--text-faint);
    }

    /* ── Formula box ── */
    .formula-box {
      background: rgba(0,0,0,0.30);
      border: 1px solid var(--glass-border);
      border-radius: var(--radius-md);
      padding: 14px 20px;
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.9rem;
      color: var(--accent-secondary);
      margin: 14px 0;
      display: flex;
      align-items: center;
      gap: 10px;
      flex-wrap: wrap;
    }
    .formula-label {
      color: var(--text-faint);
      font-size: 0.68rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.07em;
      white-space: nowrap;
    }

    /* ── Equip steps ── */
    .equip-steps {
      display: flex;
      flex-direction: column;
      gap: 12px;
      margin: 20px 0;
    }
    .equip-step {
      display: flex;
      align-items: flex-start;
      gap: 14px;
      background: var(--glass-bg);
      border: 1px solid var(--glass-border);
      border-radius: var(--radius-md);
      padding: 14px 16px;
      transition: border-color var(--transition);
    }
    .equip-step:hover { border-color: var(--glass-border-hover); }
    .equip-step-num {
      width: 28px; height: 28px;
      border-radius: 50%;
      background: rgba(var(--accent-primary-rgb), 0.25);
      border: 1px solid rgba(var(--accent-primary-rgb), 0.45);
      color: var(--accent-secondary);
      font-size: 0.8rem;
      font-weight: 800;
      display: flex; align-items: center; justify-content: center;
      flex-shrink: 0;
    }
    .equip-step-text { font-size: 0.85rem; color: var(--text-muted); line-height: 1.5; }
    .equip-step-text strong { color: var(--text); }

    /* ── Slots unlocked info ── */
    .slots-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
      gap: 12px;
      margin: 16px 0;
    }
    .slots-item {
      background: var(--glass-bg);
      border: 1px solid var(--glass-border);
      border-radius: var(--radius-md);
      padding: 12px 14px;
      text-align: center;
    }
    .slots-num   { font-size: 1.8rem; font-weight: 900; color: var(--accent-secondary); line-height: 1; margin-bottom: 4px; }
    .slots-label { font-size: 0.72rem; color: var(--text-faint); font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em; }

    /* ── Hero override ── */
    .hero-magic {
      background: linear-gradient(135deg,
        rgba(107,47,160,0.14) 0%,
        rgba(0,229,255,0.06) 50%,
        transparent 100%);
    }
  </style>
</head>
<body>

<div class="floating-particles" aria-hidden="true"></div>
<div class="sidebar-overlay" id="sidebarOverlay"></div>
<%- include('partials/sidebar', { currentPage: currentPage }) %>
<%- include('partials/header') %>


