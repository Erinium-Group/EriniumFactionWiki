            <table class="data-table" id="table-factions">
              <thead>
                <tr>
                  <th style="width:40%">Commande</th>
                  <th style="width:25%">Permission</th>
                  <th>Description</th>
                </tr>
              </thead>
              <tbody>
                <tr>
                  <td><code>/f create &lt;nom&gt; &lt;tag&gt;</code></td>
                  <td><span class="badge badge-green">Aucune</span></td>
                  <td>Créer une nouvelle faction</td>
                </tr>
                <tr>
                  <td><code>/f join &lt;faction&gt;</code></td>
                  <td><span class="badge badge-green">Aucune</span></td>
                  <td>Rejoindre une faction en mode ouvert</td>
                </tr>
                <tr>
                  <td><code>/f accept [faction]</code></td>
                  <td><span class="badge badge-green">Aucune</span></td>
                  <td>Accepter une invitation à rejoindre</td>
                </tr>
                <tr>
                  <td><code>/f deny [faction]</code></td>
                  <td><span class="badge badge-green">Aucune</span></td>
                  <td>Refuser une invitation</td>
                </tr>
                <tr>
                  <td><code>/f leave</code></td>
                  <td><span class="badge badge-green">Aucune</span></td>
                  <td>Quitter sa faction actuelle</td>
                </tr>
                <tr>
                  <td><code>/f info [faction]</code></td>
                  <td><span class="badge badge-green">Aucune</span></td>
                  <td>Afficher les informations d'une faction</td>
                </tr>
                <tr>
                  <td><code>/f list</code></td>
                  <td><span class="badge badge-green">Aucune</span></td>
                  <td>Lister toutes les factions du serveur</td>
                </tr>
                <tr>
                  <td><code>/f home</code></td>
                  <td><span class="badge badge-green">Aucune</span></td>
                  <td>Se téléporter au home de sa faction</td>
                </tr>
                <tr>
                  <td><code>/f chat &lt;canal&gt;</code></td>
                  <td><span class="badge badge-green">Aucune</span></td>
                  <td>Changer de canal de chat (faction/alliance/public)</td>
                </tr>
                <tr>
                  <td><code>/f map</code></td>
                  <td><span class="badge badge-green">Aucune</span></td>
                  <td>Afficher la carte des claims autour de soi</td>
                </tr>
                <tr>
                  <td><code>/f bank</code></td>
                  <td><span class="badge badge-green">Aucune</span></td>
                  <td>Consulter le solde de la banque de faction</td>
                </tr>
                <tr>
                  <td><code>/f invite &lt;joueur&gt;</code></td>
                  <td><span class="badge badge-cyan">Role: INVITE</span></td>
                  <td>Inviter un joueur à rejoindre la faction</td>
                </tr>
                <tr>
                  <td><code>/f kick &lt;joueur&gt;</code></td>
                  <td><span class="badge badge-cyan">Role: KICK</span></td>
                  <td>Expulser un membre de la faction</td>
                </tr>
                <tr>
                  <td><code>/f promote &lt;joueur&gt;</code></td>
                  <td><span class="badge badge-cyan">Role: PROMOTE</span></td>
                  <td>Promouvoir un membre au rang supérieur</td>
                </tr>
                <tr>
                  <td><code>/f demote &lt;joueur&gt;</code></td>
                  <td><span class="badge badge-cyan">Role: DEMOTE</span></td>
                  <td>Rétrograder un membre au rang inférieur</td>
                </tr>
                <tr>
                  <td><code>/f claim</code></td>
                  <td><span class="badge badge-cyan">Role: CLAIM</span></td>
                  <td>Revendiquer le chunk actuel pour la faction</td>
                </tr>
                <tr>
                  <td><code>/f unclaim</code></td>
                  <td><span class="badge badge-cyan">Role: UNCLAIM</span></td>
                  <td>Libérer le chunk actuel</td>
                </tr>
                <tr>
                  <td><code>/f sethome</code></td>
                  <td><span class="badge badge-cyan">Role: SETHOME</span></td>
                  <td>Définir le point de téléportation de la faction</td>
                </tr>
                <tr>
                  <td><code>/f bank deposit &lt;montant&gt;</code></td>
                  <td><span class="badge badge-cyan">Role: USE_BANK</span></td>
                  <td>Déposer de l'argent dans la banque de faction</td>
                </tr>
                <tr>
                  <td><code>/f bank withdraw &lt;montant&gt;</code></td>
                  <td><span class="badge badge-cyan">Role: USE_BANK</span></td>
                  <td>Retirer de l'argent de la banque de faction</td>
                </tr>
                <tr>
                  <td><code>/f ally &lt;faction&gt;</code></td>
                  <td><span class="badge badge-cyan">Role: SET_RELATION</span></td>
                  <td>Proposer une alliance à une autre faction</td>
                </tr>
                <tr>
                  <td><code>/f neutral &lt;faction&gt;</code></td>
                  <td><span class="badge badge-cyan">Role: SET_RELATION</span></td>
                  <td>Passer en relation neutre avec une faction</td>
                </tr>
                <tr>
                  <td><code>/f enemy &lt;faction&gt;</code></td>
                  <td><span class="badge badge-cyan">Role: SET_RELATION</span></td>
                  <td>Déclarer une faction comme ennemie</td>
