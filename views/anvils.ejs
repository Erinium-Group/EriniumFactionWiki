<%- include('partials/head', { pageTitle: 'Enclumes Moddees — EriniumFaction Wiki' }) %>
<style>
    :root {
      --valterite:        #4AE0E0;
      --valterite-rgb:    74, 224, 224;
      --valterite-dark:   rgba(74, 224, 224, 0.12);
      --valterite-border: rgba(74, 224, 224, 0.35);
      --aetherite:        #9B59B6;
      --aetherite-rgb:    155, 89, 182;
      --aetherite-dark:   rgba(155, 89, 182, 0.10);
      --aetherite-border: rgba(155, 89, 182, 0.32);
      --erinium:          #FFD700;
      --erinium-rgb:      255, 215, 0;
      --erinium-dark:     rgba(255, 215, 0, 0.12);
      --erinium-border:   rgba(255, 215, 0, 0.35);
    }

    .item-img {
      image-rendering: pixelated;
      image-rendering: crisp-edges;
      display: block;
    }

    /* ── Anvil hero cards ── */
    .anvil-hero {
      position: relative;
      border-radius: var(--radius-xl);
      padding: 32px 36px 28px;
      margin-bottom: 32px;
      overflow: hidden;
      border: 1px solid var(--glass-border);
    }
    .anvil-hero::before {
      content: '';
      position: absolute;
      top: 0; left: 10%; right: 10%;
      height: 1px;
      background: linear-gradient(90deg, transparent, rgba(255,255,255,0.22), transparent);
    }
    .anvil-hero.t1 {
      background: linear-gradient(135deg, rgba(74,224,224,0.13) 0%, var(--glass-bg) 60%);
      border-color: var(--valterite-border);
    }
    .anvil-hero.t2 {
      background: linear-gradient(135deg, rgba(155,89,182,0.10) 0%, var(--glass-bg) 60%);
      border-color: var(--aetherite-border);
    }
    .anvil-hero.t3 {
      background: linear-gradient(135deg, rgba(255,215,0,0.12) 0%, var(--glass-bg) 60%);
      border-color: var(--erinium-border);
    }

    .anvil-hero-header {
      display: flex;
      align-items: center;
      gap: 20px;
      margin-bottom: 24px;
    }

    .anvil-img {
      width: 64px;
      height: 64px;
      image-rendering: pixelated;
      filter: drop-shadow(0 0 12px rgba(255,255,255,0.3));
      flex-shrink: 0;
    }
    .t1 .anvil-img { filter: drop-shadow(0 0 12px rgba(74,224,224,0.6)); }
    .t2 .anvil-img { filter: drop-shadow(0 0 12px rgba(155,89,182,0.6)); }
    .t3 .anvil-img { filter: drop-shadow(0 0 16px rgba(255,215,0,0.8)); }

    .anvil-hero-title {
      font-size: 1.6rem;
      font-weight: 900;
      letter-spacing: -0.03em;
    }
    .t1 .anvil-hero-title { color: var(--valterite); }
    .t2 .anvil-hero-title { color: var(--aetherite); }
    .t3 .anvil-hero-title {
      background: linear-gradient(135deg, #D4A017, #FFD700);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    .anvil-hero-subtitle {
      font-size: 0.82rem;
      color: var(--text-muted);
      margin-top: 4px;
    }

    .tier-badge {
      display: inline-flex;
      align-items: center;
      gap: 5px;
      padding: 3px 10px;
      border-radius: 100px;
      font-size: 0.72rem;
      font-weight: 700;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      margin-left: 10px;
    }
    .t1 .tier-badge { background: rgba(74,224,224,0.14); border: 1px solid rgba(74,224,224,0.35); color: var(--valterite); }
    .t2 .tier-badge { background: rgba(155,89,182,0.12); border: 1px solid rgba(155,89,182,0.32); color: var(--aetherite); }
    .t3 .tier-badge { background: rgba(255,215,0,0.14); border: 1px solid rgba(255,215,0,0.35); color: var(--erinium); }

    /* ── Info blocks ── */
    .anvil-info-row {
      display: flex;
      align-items: center;
      gap: 14px;
      padding: 14px 18px;
      background: var(--glass-bg);
      border: 1px solid var(--glass-border);
      border-radius: var(--radius-md);
      margin-bottom: 16px;
    }
    .anvil-info-content { flex: 1; }
    .anvil-info-label {
      font-size: 0.65rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.10em;
      color: var(--text-faint);
      margin-bottom: 4px;
    }
    .anvil-info-value {
      font-size: 0.88rem;
      color: var(--text-muted);
      line-height: 1.55;
    }
    .anvil-info-value strong { color: var(--text); }

    /* ── Discount badge ── */
    .discount-badge {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 6px 16px;
      border-radius: 100px;
      font-size: 0.9rem;
      font-weight: 800;
      margin: 8px 0;
    }
    .t1 .discount-badge { background: rgba(74,224,224,0.14); border: 1px solid rgba(74,224,224,0.35); color: var(--valterite); }
    .t2 .discount-badge { background: rgba(155,89,182,0.12); border: 1px solid rgba(155,89,182,0.32); color: var(--aetherite); }
    .t3 .discount-badge { background: rgba(255,215,0,0.14); border: 1px solid rgba(255,215,0,0.35); color: var(--erinium); }

    /* ── Feature list ── */
    .feature-list {
      list-style: none;
      padding: 0;
      margin: 16px 0;
    }
    .feature-list li {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 8px 0;
      font-size: 0.88rem;
      color: var(--text-muted);
      border-bottom: 1px solid rgba(255,255,255,0.04);
    }
    .feature-list li:last-child { border-bottom: none; }
    .feature-icon {
      font-size: 1.1rem;
      flex-shrink: 0;
    }

    /* ── Crafting recipe ── */
    .recipe-box {
      background: var(--glass-bg);
      border: 1px solid var(--glass-border);
      border-radius: var(--radius-md);
      padding: 20px;
      margin: 16px 0;
    }
    .recipe-title {
      font-size: 0.68rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: var(--text-faint);
      margin-bottom: 12px;
    }
    .recipe-grid {
      display: grid;
      grid-template-columns: repeat(3, 52px);
      gap: 4px;
      justify-content: center;
    }
    .recipe-slot {
      width: 52px;
      height: 52px;
      background: rgba(0,0,0,0.35);
      border: 1px solid rgba(255,255,255,0.08);
      border-radius: 6px;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .recipe-slot img {
      width: 36px;
      height: 36px;
      image-rendering: pixelated;
    }
    .recipe-slot.empty {
      background: rgba(0,0,0,0.15);
    }
    .recipe-arrow {
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 1.6rem;
      color: var(--text-faint);
      margin: 12px 0;
    }
    .recipe-result {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 10px;
      margin-top: 8px;
    }
    .recipe-result img {
      width: 48px;
      height: 48px;
      image-rendering: pixelated;
    }
    .recipe-result-name {
      font-size: 0.85rem;
      font-weight: 600;
      color: var(--text);
    }

    /* ── Comparison table ── */
    .cmp-table {
      width: 100%;
      border-collapse: collapse;
      margin: 20px 0 40px;
      font-size: 0.85rem;
    }
    .cmp-table th, .cmp-table td {
      padding: 10px 14px;
      text-align: left;
      border-bottom: 1px solid var(--glass-border);
    }
    .cmp-table th {
      font-size: 0.7rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: var(--text-faint);
      background: var(--glass-bg);
    }
    .cmp-table td { color: var(--text-muted); }
    .cmp-table td:first-child { font-weight: 600; color: var(--text); }
    .cmp-table tr:hover td { background: rgba(255,255,255,0.03); }
    .cmp-vanilla { color: #aaa !important; }
    .cmp-val { color: var(--valterite) !important; }
    .cmp-aeth { color: var(--aetherite) !important; }
    .cmp-erin { color: var(--erinium) !important; }
    .cost-old {
      text-decoration: line-through;
      color: var(--text-faint) !important;
      font-size: 0.8rem;
      margin-right: 6px;
    }

    /* ── Section tag ── */
    .section-tag {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 3px 10px;
      border-radius: 100px;
      background: rgba(var(--accent-primary-rgb), 0.12);
      border: 1px solid rgba(var(--accent-primary-rgb), 0.25);
      font-size: 0.68rem;
      font-weight: 700;
      letter-spacing: 0.07em;
      text-transform: uppercase;
      color: var(--accent-secondary);
      margin-bottom: 10px;
    }
  </style>
</head>
<body>

<div class="floating-particles" aria-hidden="true"></div>
<div class="sidebar-overlay" id="sidebarOverlay"></div>
<%- include('partials/sidebar', { currentPage: currentPage }) %>
<%- include('partials/header') %>


  <div class="floating-particles">
    <div class="star" style="top:10%;left:15%;animation-delay:0s"></div>
    <div class="star" style="top:30%;left:70%;animation-delay:1s"></div>
    <div class="star" style="top:65%;left:40%;animation-delay:2s"></div>
    <div class="star" style="top:80%;left:85%;animation-delay:0.5s"></div>
    <div class="star" style="top:50%;left:5%;animation-delay:1.5s"></div>
  </div>
  <!-- ═══════════════════════ MAIN ═══════════════════════ -->
  <div class="main">

    <!-- HERO -->
    <div class="hero">
      <div class="hero-badge">⚒️ Fabrication</div>
      <h1>Enclumes Moddees</h1>
      <p>Ces enclumes fonctionnent exactement comme l'enclume de Minecraft (reparer, renommer, combiner des enchantements), mais elles coutent moins cher en XP et ne se cassent jamais !</p>
      <div class="hero-meta">
        <span class="hero-meta-item">⚒️ <strong>3 enclumes</strong></span>
        <span class="hero-meta-item">💎 <strong>Valterite → Aetherite → Erinium</strong></span>
        <span class="hero-meta-item">✨ <strong>Jusqu'a -50% de cout en XP</strong></span>
      </div>
    </div>

    <!-- CONTENT -->
    <div class="content">
      <div class="breadcrumb">
        <a href="/index">Accueil</a>
        <span class="breadcrumb-sep">›</span>
        <span class="breadcrumb-current">Enclumes Moddees</span>
      </div>

      <!-- ══════════════════════════════════════════════════════
           INTRODUCTION
           ══════════════════════════════════════════════════════ -->
      <h2 style="margin-top:32px;">Comment ca marche ?</h2>
      <p>Tu connais l'enclume classique de Minecraft ? Celle qui permet de reparer tes outils, renommer tes items et fusionner des enchantements ? Nos enclumes moddees font exactement la meme chose, mais en mieux :</p>

      <ul class="feature-list">
        <li><span class="feature-icon">💰</span> <strong>Moins cher en XP</strong> — chaque enclume reduit le cout en experience. Plus le tier est haut, plus tu economises.</li>
        <li><span class="feature-icon">🔧</span> <strong>Memes operations</strong> — reparer, renommer, combiner des enchantements, tout fonctionne comme l'enclume vanilla.</li>
        <li><span class="feature-icon">♾️</span> <strong>Incassable</strong> — contrairement a l'enclume classique qui s'abime apres quelques utilisations, ces enclumes ne se degradent jamais.</li>
        <li><span class="feature-icon">⬇️</span> <strong>Gravite</strong> — comme l'enclume vanilla, elles tombent si elles n'ont rien en dessous. Attention a ta tete !</li>
        <li><span class="feature-icon">📊</span> <strong>Affichage du prix</strong> — dans l'interface, tu vois le cout original barre et le cout reduit a cote. Pratique pour voir combien tu economises.</li>
      </ul>

      <!-- ══════════════════════════════════════════════════════
           TIER 1 — VALTERITE
           ══════════════════════════════════════════════════════ -->
      <h2>Les 3 Enclumes</h2>
      <p>Chaque enclume correspond a un materiau du jeu. Plus le materiau est rare, plus la reduction est forte !</p>

      <!-- VALTERITE ANVIL -->
      <div class="anvil-hero t1">
        <div class="anvil-hero-header">
          <img src="/img/blocks/valterite_anvil.png" alt="Enclume de Valterite" class="anvil-img" />
          <div>
            <div class="anvil-hero-title">Enclume de Valterite <span class="tier-badge">Tier 1</span></div>
            <div class="anvil-hero-subtitle">La premiere enclume ammelioree. Ideale pour tes premiers equipements moddees.</div>
          </div>
        </div>

        <span class="discount-badge">-20% de cout en XP</span>

        <div class="anvil-info-row">
          <div class="anvil-info-content">
            <div class="anvil-info-label">Reduction</div>
            <div class="anvil-info-value">Toutes les operations (reparation, renommage, fusion d'enchantements) coutent <strong>20% de moins en experience</strong> par rapport a l'enclume classique.</div>
          </div>
        </div>

        <div class="recipe-box">
          <div class="recipe-title">Recette de craft</div>
          <div class="recipe-grid">
            <div class="recipe-slot"><img src="/img/blocks/valterite_block.png" alt="Bloc de Valterite" /></div>
            <div class="recipe-slot"><img src="/img/blocks/valterite_block.png" alt="Bloc de Valterite" /></div>
            <div class="recipe-slot"><img src="/img/blocks/valterite_block.png" alt="Bloc de Valterite" /></div>
            <div class="recipe-slot empty"></div>
            <div class="recipe-slot"><img src="/img/items/valterite_ingot.png" alt="Lingot de Valterite" /></div>
            <div class="recipe-slot empty"></div>
            <div class="recipe-slot"><img src="/img/blocks/valterite_block.png" alt="Bloc de Valterite" /></div>
            <div class="recipe-slot"><img src="/img/blocks/valterite_block.png" alt="Bloc de Valterite" /></div>
            <div class="recipe-slot"><img src="/img/blocks/valterite_block.png" alt="Bloc de Valterite" /></div>
          </div>
          <div class="recipe-arrow">⬇</div>
          <div class="recipe-result">
            <img src="/img/blocks/valterite_anvil.png" alt="Enclume de Valterite" />
            <span class="recipe-result-name" style="color:var(--valterite);">Enclume de Valterite</span>
          </div>
        </div>
      </div>

      <!-- ══════════════════════════════════════════════════════
           TIER 2 — AETHERITE
           ══════════════════════════════════════════════════════ -->

      <!-- AETHERITE ANVIL -->
      <div class="anvil-hero t2">
        <div class="anvil-hero-header">
          <img src="/img/blocks/aetherite_anvil.png" alt="Enclume d'Aetherite" class="anvil-img" />
          <div>
            <div class="anvil-hero-title">Enclume d'Aetherite <span class="tier-badge">Tier 2</span></div>
            <div class="anvil-hero-subtitle">Une enclume puissante en cristal d'Aetherite. Parfaite pour l'equipement mid-game.</div>
          </div>
        </div>

        <span class="discount-badge">-30% de cout en XP</span>

        <div class="anvil-info-row">
          <div class="anvil-info-content">
            <div class="anvil-info-label">Reduction</div>
            <div class="anvil-info-value">Toutes les operations coutent <strong>30% de moins en experience</strong>. Tu gardes plus de niveaux pour tes enchantements importants.</div>
          </div>
        </div>

        <div class="recipe-box">
          <div class="recipe-title">Recette de craft</div>
          <div class="recipe-grid">
            <div class="recipe-slot"><img src="/img/blocks/aetherite_block.png" alt="Bloc d'Aetherite" /></div>
            <div class="recipe-slot"><img src="/img/blocks/aetherite_block.png" alt="Bloc d'Aetherite" /></div>
            <div class="recipe-slot"><img src="/img/blocks/aetherite_block.png" alt="Bloc d'Aetherite" /></div>
            <div class="recipe-slot empty"></div>
            <div class="recipe-slot"><img src="/img/items/aetherite_crystal.png" alt="Cristal d'Aetherite" /></div>
            <div class="recipe-slot empty"></div>
            <div class="recipe-slot"><img src="/img/blocks/aetherite_block.png" alt="Bloc d'Aetherite" /></div>
            <div class="recipe-slot"><img src="/img/blocks/aetherite_block.png" alt="Bloc d'Aetherite" /></div>
            <div class="recipe-slot"><img src="/img/blocks/aetherite_block.png" alt="Bloc d'Aetherite" /></div>
          </div>
          <div class="recipe-arrow">⬇</div>
          <div class="recipe-result">
            <img src="/img/blocks/aetherite_anvil.png" alt="Enclume d'Aetherite" />
            <span class="recipe-result-name" style="color:var(--aetherite);">Enclume d'Aetherite</span>
          </div>
        </div>
      </div>

      <!-- ══════════════════════════════════════════════════════
           TIER 3 — ERINIUM
           ══════════════════════════════════════════════════════ -->

      <!-- ERINIUM ANVIL -->
      <div class="anvil-hero t3">
        <div class="anvil-hero-header">
          <img src="/img/blocks/erinium_anvil.png" alt="Enclume d'Erinium" class="anvil-img" />
          <div>
            <div class="anvil-hero-title">Enclume d'Erinium <span class="tier-badge">Tier 3</span></div>
            <div class="anvil-hero-subtitle">L'enclume ultime. Extremement rare et precieuse, elle offre la plus grosse reduction de cout.</div>
          </div>
        </div>

        <span class="discount-badge">-50% de cout en XP</span>

        <div class="anvil-info-row">
          <div class="anvil-info-content">
            <div class="anvil-info-label">Reduction</div>
            <div class="anvil-info-value">Toutes les operations coutent <strong>moitie prix en experience</strong> ! L'enclume ideale pour enchanter et reparer ton meilleur equipement sans gaspiller tes niveaux.</div>
          </div>
        </div>

        <div class="recipe-box">
          <div class="recipe-title">Recette de craft</div>
          <div class="recipe-grid">
            <div class="recipe-slot"><img src="/img/blocks/erinium_block.png" alt="Bloc d'Erinium" /></div>
            <div class="recipe-slot"><img src="/img/blocks/erinium_block.png" alt="Bloc d'Erinium" /></div>
            <div class="recipe-slot"><img src="/img/blocks/erinium_block.png" alt="Bloc d'Erinium" /></div>
            <div class="recipe-slot empty"></div>
            <div class="recipe-slot"><img src="/img/items/erinium_fragment.png" alt="Fragment d'Erinium" /></div>
            <div class="recipe-slot empty"></div>
            <div class="recipe-slot"><img src="/img/blocks/erinium_block.png" alt="Bloc d'Erinium" /></div>
            <div class="recipe-slot"><img src="/img/blocks/erinium_block.png" alt="Bloc d'Erinium" /></div>
            <div class="recipe-slot"><img src="/img/blocks/erinium_block.png" alt="Bloc d'Erinium" /></div>
          </div>
          <div class="recipe-arrow">⬇</div>
          <div class="recipe-result">
            <img src="/img/blocks/erinium_anvil.png" alt="Enclume d'Erinium" />
            <span class="recipe-result-name" style="color:var(--erinium);">Enclume d'Erinium</span>
          </div>
        </div>
      </div>

      <!-- ══════ COMPARISON TABLE ══════ -->
      <h2>Comparaison des couts en XP</h2>
      <p>Voici des exemples concrets pour voir combien tu economises avec chaque enclume. Le cout affiche est en niveaux d'experience.</p>

      <table class="cmp-table">
        <thead>
          <tr>
            <th>Operation</th>
            <th>Vanilla</th>
            <th>Valterite (-20%)</th>
            <th>Aetherite (-30%)</th>
            <th>Erinium (-50%)</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td>Reparer une epee en diamant</td>
            <td class="cmp-vanilla">6 niv.</td>
            <td class="cmp-val"><span class="cost-old">6</span> 4 niv.</td>
            <td class="cmp-aeth"><span class="cost-old">6</span> 4 niv.</td>
            <td class="cmp-erin"><span class="cost-old">6</span> 3 niv.</td>
          </tr>
          <tr>
            <td>Combiner 2 livres Sharpness V</td>
            <td class="cmp-vanilla">30 niv.</td>
            <td class="cmp-val"><span class="cost-old">30</span> 24 niv.</td>
            <td class="cmp-aeth"><span class="cost-old">30</span> 21 niv.</td>
            <td class="cmp-erin"><span class="cost-old">30</span> 15 niv.</td>
          </tr>
        </tbody>
      </table>

      <div class="glass-card glass-card-accent accent-violet" style="margin-bottom:40px;">
        <p style="margin:0;font-size:0.9rem;">
          <strong>Conseil :</strong> Si tu as des enchantements chers a combiner (Sharpness VII, Protection VI...), garde-les pour ton enclume d'Erinium. Tu economiseras enormement d'XP ! Consulte la page <a href="/enchantments">Enchantements</a> pour voir tous les enchantements disponibles.
        </p>
      </div>

    </div><!-- /content -->

    <!-- FOOTER -->
    <footer class="footer" style="background:var(--glass-bg);border-top:1px solid var(--glass-border);padding:24px 60px;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:12px;">
      <span style="font-weight:700;font-size:0.88rem;background:linear-gradient(135deg,var(--accent-primary),var(--accent-secondary));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;">EriniumFaction Wiki</span>
      <span style="font-size:0.78rem;color:var(--text-faint);">© 2026 EriniumGroup — Minecraft 1.12.2</span>
      <div style="display:flex;gap:16px;">
        <a href="/index" style="font-size:0.78rem;color:var(--text-faint);text-decoration:none;">Accueil</a>
        <a href="/materials" style="font-size:0.78rem;color:var(--text-faint);text-decoration:none;">Materiaux</a>
        <a href="/enchantments" style="font-size:0.78rem;color:var(--text-faint);text-decoration:none;">Enchantements</a>
        <a href="/weapons" style="font-size:0.78rem;color:var(--text-faint);text-decoration:none;">Armes</a>
      </div>
    </footer>
  </div><!-- /main -->

