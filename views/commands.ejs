<%- include('partials/head', { pageTitle: 'Commandes — EriniumFaction Wiki' }) %>
<style>
    /* ── Commands-page specific styles ─────────────────────── */
    .cmd-section-icon {
      font-size: 2rem;
      display: inline-block;
      margin-bottom: 10px;
      filter: drop-shadow(0 0 10px currentColor);
    }

    .section-intro {
      display: flex;
      align-items: center;
      gap: 16px;
      background: var(--glass-bg);
      border: 1px solid var(--glass-border);
      border-radius: var(--radius-md);
      padding: 16px 20px;
      margin: 0 0 24px;
      backdrop-filter: var(--blur-glass);
    }

    .section-intro-icon {
      font-size: 2rem;
      flex-shrink: 0;
    }

    .section-intro-text {
      font-size: 0.875rem;
      color: var(--text-muted);
      line-height: 1.6;
    }

    .section-intro-text strong {
      color: var(--text);
    }

    /* Permission badge inside tables */
    .data-table .badge {
      white-space: nowrap;
    }

    /* Subtle row divider color alternation */
    .data-table tbody tr:nth-child(even) td {
      background: rgba(255,255,255,0.015);
    }

    /* Search bar for commands */
    .cmd-search-wrapper {
      position: relative;
      margin-bottom: 32px;
    }

    .cmd-search-input {
      width: 100%;
      padding: 14px 20px 14px 48px;
      background: var(--glass-bg);
      border: 1px solid var(--glass-border);
      border-radius: var(--radius-lg);
      color: var(--text);
      font-family: inherit;
      font-size: 0.95rem;
      backdrop-filter: var(--blur-glass);
      transition: border-color var(--transition), box-shadow var(--transition);
      outline: none;
    }

    .cmd-search-input:focus {
      border-color: rgba(var(--accent-secondary-rgb), 0.45);
      box-shadow: 0 0 0 3px rgba(var(--accent-secondary-rgb), 0.10), var(--shadow-glow-cyan);
    }

    .cmd-search-input::placeholder {
      color: var(--text-faint);
    }

    .cmd-search-icon {
      position: absolute;
      left: 16px;
      top: 50%;
      transform: translateY(-50%);
      color: var(--text-faint);
      pointer-events: none;
      width: 18px;
      height: 18px;
    }

    .cmd-count-badge {
      position: absolute;
      right: 16px;
      top: 50%;
      transform: translateY(-50%);
      font-size: 0.72rem;
      color: var(--text-faint);
      background: rgba(255,255,255,0.04);
      border: 1px solid var(--glass-border);
      border-radius: 20px;
      padding: 2px 10px;
      pointer-events: none;
      transition: opacity var(--transition);
    }

    /* Hidden rows during search */
    .data-table tr.cmd-hidden {
      display: none;
    }

    /* No results message */
    .cmd-no-results {
      display: none;
      text-align: center;
      padding: 32px;
      color: var(--text-faint);
      font-size: 0.9rem;
    }

    .cmd-no-results.is-visible {
      display: block;
    }

    /* Permission legend */
    .perm-legend {
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
      margin: 0 0 32px;
    }

    .perm-legend-item {
      display: flex;
      align-items: center;
      gap: 8px;
      font-size: 0.8rem;
      color: var(--text-muted);
    }

    /* Perm note box */
    .perm-note {
      font-size: 0.82rem;
      color: var(--text-muted);
      line-height: 1.7;
      padding: 14px 18px;
      background: var(--glass-bg);
      border: 1px solid var(--glass-border);
      border-radius: var(--radius-md);
      margin: 12px 0;
    }

    .perm-note code {
      background: rgba(var(--accent-secondary-rgb), 0.12);
      color: var(--accent-secondary);
      border-radius: 4px;
      padding: 1px 6px;
      font-size: 0.8rem;
    }

    /* Quick-jump anchors row */
    .jump-links {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      margin: 0 0 36px;
    }

    .jump-link {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 7px 14px;
      background: var(--glass-bg);
      border: 1px solid var(--glass-border);
      border-radius: 20px;
      font-size: 0.78rem;
      color: var(--text-muted);
      text-decoration: none;
      transition: background var(--transition), border-color var(--transition), color var(--transition);
      backdrop-filter: var(--blur-glass);
    }

    .jump-link:hover {
      background: rgba(var(--accent-primary-rgb), 0.12);
      border-color: rgba(var(--accent-primary-rgb), 0.35);
      color: var(--text);
    }

    /* Section heading with accent line */
    .cmd-section-heading {
      display: flex;
      align-items: center;
      gap: 14px;
      margin: 48px 0 20px;
    }

    .cmd-section-heading-icon {
      font-size: 1.6rem;
      flex-shrink: 0;
    }

    .cmd-section-heading h2 {
      margin: 0 !important;
    }

    /* Sticky header accent on table */
    .table-section {
      margin-bottom: 48px;
    }

    /* Permission full table */
    .perm-full-table td:first-child code {
      background: rgba(var(--warning-rgb), 0.10);
      color: var(--warning);
      border: 1px solid rgba(var(--warning-rgb), 0.20);
    }
  </style>
</head>
<body>

<div class="floating-particles" aria-hidden="true"></div>
<div class="sidebar-overlay" id="sidebarOverlay"></div>
<%- include('partials/sidebar', { currentPage: currentPage }) %>
<%- include('partials/header') %>

  <!-- ═══════════════════════════════════════════════════════════
     PAGE WRAPPER
     ═══════════════════════════════════════════════════════════ -->
<div class="page-wrapper">
  <main class="main">

    <!-- ── HERO ─────────────────────────────────────────────── -->
    <section class="hero">
      <div class="hero-badge">📋 Référence Complète</div>
      <h1>Référence des Commandes</h1>
      <p>
        Toutes les commandes à portée de main. Organisées par système, filtrables en un instant.
        Du joueur casual à l'administrateur chevronné — retrouvez instantanément la commande dont vous avez besoin.
      </p>
      <div class="hero-meta">
        <div class="hero-meta-item">🏰 <strong>Factions</strong> — 36 commandes</div>
        <div class="hero-meta-item">🌀 <strong>Téléportation</strong> — 19 commandes</div>
        <div class="hero-meta-item">⚔️ <strong>RPG</strong> — 11 commandes</div>
        <div class="hero-meta-item">📊 <strong>Grades</strong> — 18 commandes</div>
        <div class="hero-meta-item">💎 <strong>Gemmes</strong> — 2 commandes</div>
      </div>
    </section>

    <!-- ── CONTENT ───────────────────────────────────────────── -->
    <div class="content has-toc">
      <div class="content-body">

        <!-- Breadcrumb -->
        <nav class="breadcrumb" aria-label="Fil d'Ariane">
          <a href="/index">Accueil</a>
          <span class="breadcrumb-sep">›</span>
          <span class="breadcrumb-current">📋 Commandes</span>
        </nav>

        <!-- ── Légende permissions ─────────────────────────── -->
        <div class="glass-card" style="margin:0 0 28px;padding:20px 24px;" data-animate>
          <h4 style="margin:0 0 14px;font-size:0.72rem;letter-spacing:0.12em;text-transform:uppercase;color:var(--text-faint);">Légende des permissions</h4>
          <div class="perm-legend">
            <div class="perm-legend-item">
              <span class="badge badge-green">Aucune</span>
              <span>Accessible à tous les joueurs</span>
            </div>
            <div class="perm-legend-item">
              <span class="badge badge-cyan">Role: XXX</span>
              <span>Permission de rôle faction</span>
            </div>
            <div class="perm-legend-item">
              <span class="badge badge-gold">Leader</span>
              <span>Réservé au leader de faction</span>
            </div>
            <div class="perm-legend-item">
              <span class="badge badge-orange">noeud.perm</span>
              <span>Permission nommée spécifique</span>
            </div>
            <div class="perm-legend-item">
              <span class="badge badge-red">OP 2 / OP 4</span>
              <span>Niveau OP requis sur le serveur</span>
            </div>
          </div>
          <p style="font-size:0.78rem;color:var(--text-faint);margin:0;">
            Les arguments entre <code style="background:rgba(var(--accent-primary-rgb),0.12);color:#B06EDE;border-radius:4px;padding:1px 6px;">&lt;chevrons&gt;</code> sont <strong style="color:var(--text);">obligatoires</strong>.
            Ceux entre <code style="background:rgba(var(--accent-secondary-rgb),0.10);color:var(--accent-secondary);border-radius:4px;padding:1px 6px;">[crochets]</code> sont <strong style="color:var(--text);">optionnels</strong>.
          </p>
        </div>

        <!-- ── Liens rapides ───────────────────────────────── -->
        <div class="jump-links">
          <a href="#factions" class="jump-link">🏰 Factions</a>
          <a href="#rpg" class="jump-link">⚔️ RPG</a>
          <a href="#magie" class="jump-link">✨ Magie</a>
          <a href="#economie" class="jump-link">💰 Économie</a>
          <a href="#chat" class="jump-link">💬 Chat</a>
          <a href="#minage" class="jump-link">⛏️ Minage</a>
          <a href="#teleportation" class="jump-link">🌀 Téléportation</a>
          <a href="#anti-cheat" class="jump-link">🛡️ Anti-Cheat</a>
          <a href="#outils-serveur" class="jump-link">⚙️ Serveur</a>
          <a href="#gemmes" class="jump-link">💎 Gemmes</a>
          <a href="#grades" class="jump-link">🎖️ Grades</a>
          <a href="#permissions" class="jump-link">🔐 Permissions</a>
        </div>

        <!-- ── Barre de recherche de commandes ─────────────── -->
        <div class="cmd-search-wrapper">
          <svg class="cmd-search-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
          </svg>
          <input
            type="search"
            id="cmdFilterInput"
            class="cmd-search-input"
            placeholder="Filtrer les commandes… ex: /f claim, bank, setlevel…"
            autocomplete="off"
            spellcheck="false"
          />
          <span class="cmd-count-badge" id="cmdCountBadge">96 commandes</span>
        </div>

        <!-- ══════════════════════════════════════════════════
             1. FACTIONS
             ══════════════════════════════════════════════════ -->
        <section id="factions" class="table-section">
          <div class="cmd-section-heading">
            <span class="cmd-section-heading-icon">🏰</span>
            <h2>Factions <code style="font-size:0.7em;background:rgba(var(--accent-primary-rgb),0.12);color:#B06EDE;border-radius:6px;padding:2px 10px;vertical-align:middle;">/f</code></h2>
          </div>

          <div class="section-intro">
            <span class="section-intro-icon">📖</span>
            <div class="section-intro-text">
