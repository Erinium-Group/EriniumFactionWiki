        <!-- ══════════════════════════════════════════════════
             2. RPG
             ══════════════════════════════════════════════════ -->
        <section id="rpg" class="table-section">
          <div class="cmd-section-heading">
            <span class="cmd-section-heading-icon">⚔️</span>
            <h2>Système RPG <code style="font-size:0.7em;background:rgba(var(--accent-primary-rgb),0.12);color:#B06EDE;border-radius:6px;padding:2px 10px;vertical-align:middle;">/rpg</code></h2>
          </div>

          <div class="section-intro">
            <span class="section-intro-icon">📊</span>
            <div class="section-intro-text">
              Gérez votre progression RPG : stats, perks, défis quotidiens, respec et prestige.
              Les commandes admin permettent de contrôler finement la progression de n'importe quel joueur.
            </div>
          </div>

          <div class="table-wrapper">
            <table class="data-table" id="table-rpg">
              <thead>
                <tr>
                  <th style="width:40%">Commande</th>
                  <th style="width:25%">Permission</th>
                  <th>Description</th>
                </tr>
              </thead>
              <tbody>
                <tr>
                  <td><code>/rpg stats</code></td>
                  <td><span class="badge badge-green">Aucune</span></td>
                  <td>Afficher ses statistiques RPG actuelles</td>
                </tr>
                <tr>
                  <td><code>/rpg perks</code></td>
                  <td><span class="badge badge-green">Aucune</span></td>
                  <td>Consulter ses perks débloqués et disponibles</td>
                </tr>
                <tr>
                  <td><code>/rpg challenges</code></td>
                  <td><span class="badge badge-green">Aucune</span></td>
                  <td>Voir les défis quotidiens et leur progression</td>
                </tr>
                <tr>
                  <td><code>/rpg invest &lt;stat&gt;</code></td>
                  <td><span class="badge badge-green">Aucune</span></td>
                  <td>Investir un point de statistique disponible</td>
                </tr>
                <tr>
                  <td><code>/rpg chooseperk &lt;tier&gt; &lt;index&gt;</code></td>
                  <td><span class="badge badge-green">Aucune</span></td>
                  <td>Sélectionner un perk dans un palier donné</td>
                </tr>
                <tr>
                  <td><code>/rpg respec confirm</code></td>
                  <td><span class="badge badge-green">Aucune</span></td>
                  <td>Rembourser tous les points de stats investis</td>
                </tr>
                <tr>
                  <td><code>/rpg respecfull confirm</code></td>
                  <td><span class="badge badge-green">Aucune</span></td>
                  <td>Respec complet : stats et perks réinitialisés</td>
                </tr>
                <tr>
                  <td><code>/rpg prestige confirm</code></td>
                  <td><span class="badge badge-green">Aucune</span></td>
                  <td>Activer le prestige (reset niveau contre bonus permanent)</td>
                </tr>
                <tr>
                  <td><code>/rpg admin setlevel &lt;joueur&gt; &lt;niveau&gt;</code></td>
                  <td><span class="badge badge-red">OP 2</span></td>
                  <td>Définir le niveau RPG d'un joueur</td>
                </tr>
                <tr>
                  <td><code>/rpg admin givexp &lt;joueur&gt; &lt;xp&gt;</code></td>
                  <td><span class="badge badge-red">OP 2</span></td>
                  <td>Donner de l'expérience RPG à un joueur</td>
                </tr>
                <tr>
                  <td><code>/rpg admin resetdata &lt;joueur&gt;</code></td>
                  <td><span class="badge badge-red">OP 2</span></td>
                  <td>Réinitialiser toutes les données RPG d'un joueur</td>
                </tr>
              </tbody>
            </table>
            <div class="cmd-no-results" id="no-results-rpg">Aucune commande ne correspond à votre recherche.</div>
          </div>
        </section>

        <!-- ══════════════════════════════════════════════════
             3. MAGIE
             ══════════════════════════════════════════════════ -->
        <section id="magie" class="table-section">
