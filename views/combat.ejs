<%- include('partials/head', { pageTitle: 'Combat — EriniumFaction Wiki' }) %>
<style>
    /* ── Hero override — couleur combat rouge/orange ── */
    .hero-combat {
      background: linear-gradient(135deg,
        rgba(231, 76, 60, 0.14) 0%,
        rgba(243, 156, 18, 0.07) 50%,
        transparent 100%);
    }
    .hero-combat::before {
      background: radial-gradient(circle, rgba(231, 76, 60, 0.18), transparent 70%);
    }
    .hero-combat::after {
      background: radial-gradient(circle, rgba(243, 156, 18, 0.10), transparent 70%);
    }

    /* ── Alert PvP 1.8 — mise en avant maximale ── */
    .alert-pvp18 {
      position: relative;
      background: linear-gradient(135deg,
        rgba(231, 76, 60, 0.12) 0%,
        rgba(243, 156, 18, 0.07) 100%);
      border: 1px solid rgba(231, 76, 60, 0.40);
      border-left: 4px solid var(--danger);
      border-radius: var(--radius-lg);
      padding: 22px 24px;
      margin: 20px 0;
      overflow: hidden;
    }
    .alert-pvp18::before {
      content: '';
      position: absolute;
      top: 0; left: 10%; right: 10%;
      height: 1px;
      background: linear-gradient(90deg, transparent, rgba(231,76,60,0.45), transparent);
    }
    .alert-pvp18-title {
      font-size: 1.05rem;
      font-weight: 800;
      color: var(--danger);
      margin-bottom: 6px;
      display: flex;
      align-items: center;
      gap: 8px;
    }
    .alert-pvp18-desc {
      font-size: 0.88rem;
      color: var(--text-muted);
      line-height: 1.65;
    }
    .alert-pvp18-glow {
      position: absolute;
      right: -40px;
      top: -40px;
      width: 160px;
      height: 160px;
      background: radial-gradient(circle, rgba(231,76,60,0.14), transparent 70%);
      border-radius: 50%;
      pointer-events: none;
    }

    /* ── Feature list PvP 1.8 ── */
    .pvp18-list {
      list-style: none;
      padding: 0;
      margin: 16px 0;
      display: flex;
      flex-direction: column;
      gap: 10px;
    }
    .pvp18-item {
      display: flex;
      align-items: flex-start;
      gap: 12px;
      padding: 13px 16px;
      background: var(--glass-bg);
      border: 1px solid var(--glass-border);
      border-radius: var(--radius-md);
      font-size: 0.875rem;
      color: var(--text-muted);
      transition: border-color var(--transition), background var(--transition);
    }
    .pvp18-item:hover {
      border-color: var(--glass-border-hover);
      background: var(--surface-hover);
    }
    .pvp18-item-icon {
      font-size: 1.2rem;
      flex-shrink: 0;
      margin-top: 1px;
    }
    .pvp18-item strong {
      color: var(--text);
      font-weight: 700;
      display: block;
      margin-bottom: 2px;
    }

    /* ── Scaling stats grid ── */
    .scaling-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
      gap: 16px;
      margin: 20px 0;
    }
    .scaling-card {
      position: relative;
      background: var(--glass-bg);
      backdrop-filter: var(--blur-glass);
      -webkit-backdrop-filter: var(--blur-glass);
      border: 1px solid var(--glass-border);
      border-radius: var(--radius-lg);
      padding: 20px;
      overflow: hidden;
      transition: transform var(--transition), box-shadow var(--transition), border-color var(--transition);
    }
    .scaling-card::before {
      content: '';
      position: absolute;
      top: 0; left: 10%; right: 10%;
      height: 1px;
      background: linear-gradient(90deg, transparent, rgba(255,255,255,0.20), transparent);
    }
    .scaling-card:hover {
      transform: translateY(-2px);
      box-shadow: var(--shadow-md);
      border-color: var(--glass-border-hover);
    }
    .scaling-card-offense { border-top: 3px solid var(--danger); }
    .scaling-card-defense { border-top: 3px solid #5B9BD5; }

    .scaling-card-title {
      display: flex;
      align-items: center;
      gap: 8px;
      font-size: 0.85rem;
      font-weight: 800;
      text-transform: uppercase;
      letter-spacing: 0.07em;
      margin-bottom: 14px;
    }
    .scaling-offense { color: var(--danger); }
    .scaling-defense { color: #5B9BD5; }

    .scaling-stat-row {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 9px 0;
      border-bottom: 1px solid var(--glass-border);
      font-size: 0.84rem;
    }
    .scaling-stat-row:last-child { border-bottom: none; }
    .scaling-stat-name {
      color: var(--text-muted);
      font-weight: 500;
    }
    .scaling-stat-value {
      font-weight: 700;
      color: var(--text);
      font-variant-numeric: tabular-nums;
    }
    .scaling-stat-value.val-red   { color: var(--danger); }
    .scaling-stat-value.val-blue  { color: #5B9BD5; }
    .scaling-stat-value.val-gold  { color: var(--accent-gold); }
    .scaling-stat-value.val-green { color: var(--success); }
    .scaling-stat-value.val-cyan  { color: var(--accent-secondary); }
    .scaling-stat-value.val-purple { color: #B06EDE; }

    /* ── Zones de combat ── */
    .zone-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
      gap: 16px;
      margin: 20px 0;
    }
    .zone-card {
      position: relative;
      background: var(--glass-bg);
      backdrop-filter: var(--blur-glass);
      -webkit-backdrop-filter: var(--blur-glass);
      border: 1px solid var(--glass-border);
      border-radius: var(--radius-lg);
      padding: 20px 18px;
      text-align: center;
      overflow: hidden;
      transition: transform var(--transition), box-shadow var(--transition), border-color var(--transition);
    }
    .zone-card::before {
      content: '';
      position: absolute;
      top: 0; left: 10%; right: 10%;
      height: 1px;
      background: linear-gradient(90deg, transparent, rgba(255,255,255,0.18), transparent);
    }
    .zone-card:hover {
      transform: translateY(-3px);
      box-shadow: var(--shadow-md);
    }
    .zone-safe     { border-top: 3px solid var(--success); }
    .zone-warzone  { border-top: 3px solid var(--danger); }
    .zone-faction  { border-top: 3px solid var(--warning); }
    .zone-wild     { border-top: 3px solid var(--text-faint); }

    .zone-icon {
      font-size: 2rem;
      margin-bottom: 10px;
      display: block;
    }
    .zone-name {
      font-size: 0.9rem;
      font-weight: 800;
      color: var(--text);
      margin-bottom: 4px;
    }
    .zone-status {
      font-size: 0.72rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      margin-bottom: 10px;
    }
    .zone-status-safe     { color: var(--success); }
    .zone-status-war      { color: var(--danger); }
    .zone-status-faction  { color: var(--warning); }
    .zone-status-wild     { color: var(--text-muted); }
    .zone-desc {
      font-size: 0.78rem;
      color: var(--text-faint);
      line-height: 1.5;
    }

    /* ── Zone rules list ── */
    .zone-rules {
      list-style: none;
      padding: 0;
      margin: 16px 0;
      display: flex;
      flex-direction: column;
      gap: 8px;
    }
    .zone-rule-item {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 10px 14px;
      background: var(--glass-bg);
      border: 1px solid var(--glass-border);
      border-radius: var(--radius-md);
      font-size: 0.84rem;
      color: var(--text-muted);
      transition: border-color var(--transition);
    }
    .zone-rule-item:hover { border-color: var(--glass-border-hover); }
    .zone-rule-item.rule-no  { border-left: 3px solid var(--danger); }
    .zone-rule-item.rule-yes { border-left: 3px solid var(--success); }
    .zone-rule-item.rule-info { border-left: 3px solid var(--accent-secondary); }
    .zone-rule-icon { font-size: 1rem; flex-shrink: 0; }

    /* ── Armor comparison ── */
    .armor-highlight {
      background: rgba(107, 47, 160, 0.08) !important;
    }
    .armor-highlight td { color: var(--text) !important; }
    .armor-endgame {
      background: rgba(255, 215, 0, 0.06) !important;
    }
    .armor-endgame td { color: var(--text) !important; }

    /* ── Magic damage section ── */
    .magic-dmg-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
      gap: 14px;
      margin: 20px 0;
    }
    .magic-dmg-card {
      position: relative;
      background: var(--glass-bg);
      backdrop-filter: var(--blur-glass);
      -webkit-backdrop-filter: var(--blur-glass);
      border: 1px solid var(--glass-border);
      border-radius: var(--radius-md);
      padding: 18px;
      overflow: hidden;
      transition: transform var(--transition), box-shadow var(--transition);
    }
    .magic-dmg-card::before {
      content: '';
      position: absolute;
      top: 0; left: 10%; right: 10%;
      height: 1px;
      background: linear-gradient(90deg, transparent, rgba(255,255,255,0.18), transparent);
    }
    .magic-dmg-card:hover {
      transform: translateY(-2px);
      box-shadow: var(--shadow-md);
    }
    .magic-dmg-card.card-bypass { border-left: 3px solid #B06EDE; }
    .magic-dmg-card.card-reduce { border-left: 3px solid #5B9BD5; }
    .magic-dmg-card.card-boost  { border-left: 3px solid #818CF8; }
    .magic-dmg-card.card-ignore { border-left: 3px solid var(--danger); }
    .magic-dmg-title {
      font-size: 0.88rem;
      font-weight: 800;
      color: var(--text);
      margin-bottom: 8px;
      display: flex;
      align-items: center;
      gap: 7px;
    }
    .magic-dmg-desc {
      font-size: 0.8rem;
      color: var(--text-muted);
      line-height: 1.6;
    }

    /* ── Death consequences list ── */
    .death-list {
      list-style: none;
      padding: 0;
      margin: 16px 0;
      display: flex;
      flex-direction: column;
      gap: 10px;
    }
    .death-item {
      display: flex;
      align-items: flex-start;
      gap: 12px;
      padding: 14px 16px;
      background: var(--glass-bg);
      border: 1px solid var(--glass-border);
      border-radius: var(--radius-md);
      font-size: 0.875rem;
      color: var(--text-muted);
      transition: border-color var(--transition), background var(--transition);
    }
    .death-item:hover {
      border-color: var(--glass-border-hover);
    }
    .death-item.death-bad  { border-left: 3px solid var(--danger); }
    .death-item.death-perk { border-left: 3px solid #B06EDE; }
    .death-item.death-spell { border-left: 3px solid #818CF8; }
    .death-item.death-bonus { border-left: 3px solid var(--accent-gold); }
    .death-item-icon {
      font-size: 1.15rem;
      flex-shrink: 0;
      margin-top: 1px;
    }
    .death-item strong {
      color: var(--text);
      font-weight: 700;
      display: block;
      margin-bottom: 2px;
    }

    /* ── Nameplates ── */
    .nameplate-preview {
      position: relative;
      background: rgba(0, 0, 0, 0.55);
      border: 1px solid var(--glass-border);
      border-radius: var(--radius-lg);
      padding: 28px 24px;
      margin: 20px 0;
      text-align: center;
      overflow: hidden;
    }
    .nameplate-preview::before {
      content: '';
      position: absolute;
      top: 0; left: 10%; right: 10%;
      height: 1px;
      background: linear-gradient(90deg, transparent, rgba(255,255,255,0.16), transparent);
    }
    .nameplate-demo {
      display: inline-flex;
      flex-direction: column;
      align-items: center;
      gap: 5px;
      padding: 14px 24px;
      background: rgba(0,0,0,0.72);
      border: 1px solid rgba(255,255,255,0.08);
      border-radius: var(--radius-md);
      backdrop-filter: blur(12px);
    }
    .nameplate-faction-tag {
      font-size: 0.68rem;
      font-weight: 800;
      letter-spacing: 0.10em;
      text-transform: uppercase;
      color: var(--accent-gold);
      text-shadow: 0 0 8px rgba(255,215,0,0.5);
    }
    .nameplate-player-name {
      font-size: 1rem;
      font-weight: 800;
      color: var(--text);
      letter-spacing: -0.01em;
      display: flex;
      align-items: center;
      gap: 6px;
    }
    .nameplate-grade {
      font-size: 0.7rem;
      font-weight: 700;
      color: #B06EDE;
      text-transform: uppercase;
      letter-spacing: 0.08em;
    }
    .nameplate-prestige {
      font-size: 0.75rem;
      letter-spacing: 1px;
      color: var(--accent-gold);
    }
    .nameplate-hp-bar {
      width: 120px;
      height: 6px;
      background: rgba(255,255,255,0.08);
      border-radius: 100px;
      overflow: hidden;
      margin-top: 2px;
    }
    .nameplate-hp-fill {
      height: 100%;
      width: 78%;
      background: linear-gradient(90deg, #c0392b, var(--danger));
      border-radius: 100px;
    }
    .nameplate-hp-text {
      font-size: 0.65rem;
      color: var(--text-faint);
      font-variant-numeric: tabular-nums;
    }
    .nameplate-note {
      font-size: 0.78rem;
      color: var(--text-faint);
      margin-top: 14px;
      font-style: italic;
    }

    .nameplate-info-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
      gap: 12px;
      margin: 16px 0;
    }
    .nameplate-info-item {
      display: flex;
      align-items: flex-start;
      gap: 10px;
      padding: 12px 14px;
      background: var(--glass-bg);
      border: 1px solid var(--glass-border);
      border-radius: var(--radius-md);
      font-size: 0.82rem;
      color: var(--text-muted);
      transition: border-color var(--transition);
    }
    .nameplate-info-item:hover { border-color: var(--glass-border-hover); }
    .nameplate-info-item strong {
      color: var(--text);
      display: block;
      font-weight: 700;
      margin-bottom: 2px;
    }
    .nameplate-info-icon { font-size: 1.1rem; flex-shrink: 0; margin-top: 1px; }

    /* ── Build cards combat ── */
    .build-combat-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
      gap: 20px;
      margin: 24px 0;
    }
    .build-combat-card {
      position: relative;
      background: var(--glass-bg);
      backdrop-filter: var(--blur-glass);
      -webkit-backdrop-filter: var(--blur-glass);
      border: 1px solid var(--glass-border);
      border-radius: var(--radius-lg);
      padding: 24px 20px;
      overflow: hidden;
      transition: transform var(--transition), box-shadow var(--transition), border-color var(--transition);
    }
    .build-combat-card::before {
      content: '';
      position: absolute;
      top: 0; left: 10%; right: 10%;
      height: 1px;
      background: linear-gradient(90deg, transparent, rgba(255,255,255,0.22), transparent);
    }
    .build-combat-card:hover {
      transform: translateY(-3px);
      box-shadow: var(--shadow-md), var(--shadow-glow);
    }
    .build-combat-card.build-off  { border-top: 3px solid var(--danger); }
    .build-combat-card.build-def  { border-top: 3px solid #5B9BD5; }
    .build-combat-card.build-supp { border-top: 3px solid #818CF8; }

    .build-combat-card.build-off:hover  { border-color: rgba(231,76,60,0.35); box-shadow: var(--shadow-md), 0 0 24px rgba(231,76,60,0.18); }
    .build-combat-card.build-def:hover  { border-color: rgba(91,155,213,0.35); box-shadow: var(--shadow-md), 0 0 24px rgba(91,155,213,0.18); }
    .build-combat-card.build-supp:hover { border-color: rgba(129,140,248,0.35); box-shadow: var(--shadow-md), 0 0 24px rgba(129,140,248,0.18); }

    .build-combat-icon {
      font-size: 2.4rem;
      margin-bottom: 10px;
      display: block;
      filter: drop-shadow(0 2px 8px rgba(0,0,0,0.5));
    }
    .build-combat-name {
      font-size: 1.05rem;
      font-weight: 900;
      color: var(--text);
      margin-bottom: 3px;
      letter-spacing: -0.01em;
    }
    .build-combat-role {
      font-size: 0.72rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.09em;
      margin-bottom: 14px;
    }
    .build-role-off  { color: var(--danger); }
    .build-role-def  { color: #5B9BD5; }
    .build-role-supp { color: #818CF8; }

    .build-combat-stat {
      font-size: 0.8rem;
      color: var(--text-muted);
      margin-bottom: 5px;
    }
    .build-combat-stat strong { color: var(--text); }

    .build-combat-tags {
      display: flex;
      flex-wrap: wrap;
      gap: 5px;
      margin-top: 14px;
    }
    .build-tag {
      font-size: 0.67rem;
      font-weight: 700;
      padding: 3px 9px;
      border-radius: 100px;
      background: rgba(var(--accent-primary-rgb), 0.14);
      border: 1px solid rgba(var(--accent-primary-rgb), 0.28);
      color: var(--accent-secondary);
    }
    .build-tag.tag-off  { background: rgba(231,76,60,0.12); border-color: rgba(231,76,60,0.25); color: #ff8a7a; }
    .build-tag.tag-def  { background: rgba(91,155,213,0.12); border-color: rgba(91,155,213,0.25); color: #8ec6f0; }
    .build-tag.tag-supp { background: rgba(129,140,248,0.12); border-color: rgba(129,140,248,0.25); color: #b0b8ff; }

    /* ── Section intro tags ── */
    .section-tag {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 3px 10px;
      border-radius: 100px;
      background: rgba(var(--accent-primary-rgb), 0.12);
      border: 1px solid rgba(var(--accent-primary-rgb), 0.25);
      font-size: 0.68rem;
      font-weight: 700;
      letter-spacing: 0.07em;
      text-transform: uppercase;
      color: var(--accent-secondary);
      margin-bottom: 10px;
    }

    /* ── Generic alert ── */
    .alert {
      display: flex;
      align-items: flex-start;
      gap: 14px;
      padding: 16px 18px;
      border-radius: var(--radius-md);
      margin: 16px 0;
      font-size: 0.875rem;
    }
    .alert-icon { font-size: 1.2rem; flex-shrink: 0; margin-top: 1px; }
    .alert-body { flex: 1; }
    .alert-title { font-weight: 700; color: var(--text); display: block; margin-bottom: 3px; }
    .alert-desc  { color: var(--text-muted); line-height: 1.6; }
    .alert-info  {
      background: rgba(var(--info-rgb), 0.08);
      border: 1px solid rgba(var(--info-rgb), 0.25);
      border-left: 3px solid var(--info);
    }
    .alert-warn  {
      background: rgba(var(--warning-rgb), 0.08);
      border: 1px solid rgba(var(--warning-rgb), 0.25);
      border-left: 3px solid var(--warning);
    }
    .alert-danger {
      background: rgba(var(--danger-rgb), 0.10);
      border: 1px solid rgba(var(--danger-rgb), 0.28);
      border-left: 3px solid var(--danger);
    }
    .alert-success {
      background: rgba(var(--success-rgb), 0.08);
      border: 1px solid rgba(var(--success-rgb), 0.25);
      border-left: 3px solid var(--success);
    }
  </style>
</head>
<body>

<div class="floating-particles" aria-hidden="true"></div>
<div class="sidebar-overlay" id="sidebarOverlay"></div>
<%- include('partials/sidebar', { currentPage: currentPage }) %>
<%- include('partials/header') %>


<!-- ─── Floating Particles ──────────────────────────────────── -->
<div class="floating-particles" aria-hidden="true">
  <span class="star" style="left:8%;top:14%;animation-delay:0s;animation-duration:3.1s;"></span>
  <span class="star" style="left:22%;top:6%;animation-delay:0.9s;animation-duration:4.3s;"></span>
  <span class="star" style="left:47%;top:19%;animation-delay:0.4s;animation-duration:3.8s;"></span>
  <span class="star" style="left:69%;top:9%;animation-delay:1.8s;animation-duration:2.7s;"></span>
  <span class="star" style="left:85%;top:28%;animation-delay:0.6s;animation-duration:4.6s;"></span>
  <span class="star" style="left:34%;top:52%;animation-delay:2.1s;animation-duration:3.3s;"></span>
  <span class="star" style="left:60%;top:68%;animation-delay:0.2s;animation-duration:5.1s;"></span>
  <span class="star" style="left:3%;top:77%;animation-delay:2.7s;animation-duration:3.9s;"></span>
  <span class="star" style="left:94%;top:60%;animation-delay:1.4s;animation-duration:4.0s;"></span>
  <span class="star" style="left:78%;top:44%;animation-delay:3.2s;animation-duration:3.6s;"></span>
</div>

<!-- ─── Sidebar ──────────────────────────────────────────────── -->
  <!-- ─── Page Wrapper ──────────────────────────────────────────── -->
<div class="page-wrapper">
  <main class="main" id="main-content">

    <!-- ─── Hero ─────────────────────────────────────────────── -->
    <section class="hero hero-combat" aria-labelledby="hero-title">
      <span class="hero-badge">🗡️ Combat &amp; PvP</span>
      <h1 id="hero-title">Dominez le Champ de Bataille</h1>
      <p>PvP 1.8 pur, sans cooldown, sans pitié. Chaque clic compte, chaque milliseconde décide de votre survie. Maîtrisez le strafing, spammez vos attaques, écrasez vos ennemis avec la puissance brute de votre build RPG — bienvenue dans le vrai PvP Minecraft.</p>
      <div class="hero-meta">
        <div class="hero-meta-item">⚡ <strong>PvP :</strong> Style 1.8 — Pas de cooldown</div>
        <div class="hero-meta-item">💀 <strong>Zones :</strong> Safezone / Warzone / Faction</div>
        <div class="hero-meta-item">🛡️ <strong>Armures :</strong> 3 sets custom + diamant</div>
        <div class="hero-meta-item">🔮 <strong>Magie :</strong> Contourne l'armure classique</div>
      </div>
    </section>

    <!-- ─── Content ───────────────────────────────────────────── -->
    <div class="content has-toc">
      <div class="content-body">

        <!-- Breadcrumb -->
