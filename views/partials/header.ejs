<header class="site-header" id="wiki-header">
  <button class="header-hamburger" data-hamburger aria-label="Menu" aria-expanded="false">☰</button>
  <div class="header-search-wrap" data-search-wrapper>
    <input class="header-search" type="search" placeholder="Rechercher… (Ctrl+K)" autocomplete="off" data-search-input aria-label="Rechercher dans le wiki">
    <div class="search-results" data-search-results></div>
  </div>
  <button class="header-theme-btn" data-theme-toggle aria-label="Changer le thème"><span class="theme-icon">🌙</span></button>
  <button class="header-theme-btn" data-translate-toggle aria-label="Traduire" style="margin-left:4px;">🌐</button>
</header>
