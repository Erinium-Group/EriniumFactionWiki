<%- include('partials/head', { pageTitle: 'Armures — EriniumFaction Wiki' }) %>
<style>
    :root {
      --valterite:        #4AE0E0;
      --valterite-border: rgba(74, 224, 224, 0.35);
      --aetherite:        #9B59B6;
      --aetherite-border: rgba(155, 89, 182, 0.32);
      --erinium:          #FFD700;
      --erinium-border:   rgba(255, 215, 0, 0.35);
    }

    .item-img { image-rendering: pixelated; image-rendering: crisp-edges; display: block; }

    /* ── Armor tier header ── */
    .armor-tier-header {
      display: flex;
      align-items: center;
      gap: 16px;
      padding: 24px 28px;
      border-radius: var(--radius-xl) var(--radius-xl) 0 0;
      border: 1px solid var(--glass-border);
      border-bottom: none;
      position: relative;
      overflow: hidden;
    }
    .armor-tier-header::before {
      content: '';
      position: absolute;
      top: 0; left: 10%; right: 10%;
      height: 1px;
      background: linear-gradient(90deg, transparent, rgba(255,255,255,0.22), transparent);
    }
    .at-t1 { background: linear-gradient(135deg, rgba(74,224,224,0.13) 0%, var(--glass-bg) 70%); border-color: var(--valterite-border); }
    .at-t2 { background: linear-gradient(135deg, rgba(155,89,182,0.10) 0%, var(--glass-bg) 70%);   border-color: var(--aetherite-border); }
    .at-t3 { background: linear-gradient(135deg, rgba(255,215,0,0.12) 0%, var(--glass-bg) 70%);  border-color: var(--erinium-border); }

    .armor-tier-icon { font-size: 2.2rem; line-height: 1; }
    .armor-tier-title {
      font-size: 1.35rem;
      font-weight: 800;
      letter-spacing: -0.02em;
    }
    .at-t1 .armor-tier-title { color: var(--valterite); }
    .at-t2 .armor-tier-title { color: var(--aetherite); }
    .at-t3 .armor-tier-title {
      background: linear-gradient(135deg, #D4A017, #FFD700);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }
    .armor-tier-subtitle { font-size: 0.82rem; color: var(--text-muted); margin-top: 3px; }

    .tier-pill {
      font-size: 0.65rem;
      font-weight: 700;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      padding: 2px 8px;
      border-radius: 100px;
      margin-left: 10px;
    }
    .at-t1 .tier-pill { background: rgba(74,224,224,0.14); border: 1px solid rgba(74,224,224,0.35); color: var(--valterite); }
    .at-t2 .tier-pill { background: rgba(155,89,182,0.12);  border: 1px solid rgba(155,89,182,0.32);  color: var(--aetherite); }
    .at-t3 .tier-pill { background: rgba(255,215,0,0.14); border: 1px solid rgba(255,215,0,0.35); color: var(--erinium); }

    /* ── Armor pieces grid ── */
    .armor-pieces-body {
      border: 1px solid var(--glass-border);
      border-top: none;
      border-radius: 0 0 var(--radius-xl) var(--radius-xl);
      padding: 20px 24px 24px;
      margin-bottom: 32px;
      background: var(--glass-bg);
    }
    .at-t1.armor-pieces-body { border-color: var(--valterite-border); }
    .at-t2.armor-pieces-body { border-color: var(--aetherite-border); }
    .at-t3.armor-pieces-body { border-color: var(--erinium-border); }

    .armor-pieces-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 12px;
      margin-bottom: 20px;
    }
    @media (max-width: 600px) { .armor-pieces-grid { grid-template-columns: repeat(2, 1fr); } }

    .armor-piece-card {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 8px;
      padding: 16px 10px;
      background: rgba(255,255,255,0.04);
      border: 1px solid var(--glass-border);
      border-radius: var(--radius-md);
      text-align: center;
      transition: transform var(--transition), border-color var(--transition), box-shadow var(--transition);
    }
    .armor-piece-card:hover { transform: translateY(-2px); }
    .at-t1 .armor-piece-card:hover { border-color: var(--valterite-border); box-shadow: 0 4px 16px rgba(74,224,224,0.15); }
    .at-t2 .armor-piece-card:hover { border-color: var(--aetherite-border); box-shadow: 0 4px 16px rgba(155,89,182,0.12); }
    .at-t3 .armor-piece-card:hover { border-color: var(--erinium-border);   box-shadow: 0 4px 16px rgba(255,215,0,0.15); }

    .armor-piece-img {
      width: 48px; height: 48px;
      image-rendering: pixelated;
    }
    .at-t1 .armor-piece-img { filter: drop-shadow(0 2px 8px rgba(74,224,224,0.5)); }
    .at-t2 .armor-piece-img { filter: drop-shadow(0 2px 8px rgba(155,89,182,0.5)); }
    .at-t3 .armor-piece-img { filter: drop-shadow(0 2px 8px rgba(255,215,0,0.7)); }

    .armor-piece-name { font-size: 0.78rem; font-weight: 600; color: var(--text); }

    .armor-piece-stats {
      display: flex;
      flex-direction: column;
      gap: 3px;
      width: 100%;
    }
    .armor-stat-row {
      display: flex;
      justify-content: space-between;
      font-size: 0.7rem;
    }
    .armor-stat-key { color: var(--text-faint); }
    .armor-stat-val { color: var(--text-muted); font-weight: 600; }

    .piece-effect {
      font-size: 0.68rem;
      color: var(--accent-secondary);
      font-weight: 600;
      text-align: center;
      padding: 3px 6px;
      background: rgba(0,229,255,0.08);
      border-radius: 4px;
      line-height: 1.4;
    }

    /* ── Set bonus block ── */
    .set-bonus-block {
      display: flex;
      align-items: flex-start;
      gap: 14px;
      padding: 16px 18px;
      border-radius: var(--radius-md);
      margin-top: 8px;
    }
    .at-t1 .set-bonus-block { background: rgba(74,224,224,0.09); border: 1px solid rgba(74,224,224,0.30); }
    .at-t2 .set-bonus-block { background: rgba(155,89,182,0.07);   border: 1px solid rgba(155,89,182,0.28); }
    .at-t3 .set-bonus-block { background: rgba(255,215,0,0.09);  border: 1px solid rgba(255,215,0,0.30); }

    .set-bonus-icon { font-size: 1.6rem; flex-shrink: 0; }
    .set-bonus-title {
      font-size: 0.72rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: var(--text-faint);
      margin-bottom: 4px;
    }
    .set-bonus-text { font-size: 0.88rem; color: var(--text-muted); line-height: 1.55; }
    .at-t1 .set-bonus-text strong { color: var(--valterite); }
    .at-t2 .set-bonus-text strong { color: var(--aetherite); }
    .at-t3 .set-bonus-text strong { color: var(--erinium); }

    /* ── Comparison table ── */
    .cmp-table {
      width: 100%;
      border-collapse: collapse;
      margin: 16px 0 32px;
      font-size: 0.83rem;
    }
    .cmp-table th, .cmp-table td {
      padding: 9px 12px;
      text-align: left;
      border-bottom: 1px solid var(--glass-border);
    }
    .cmp-table th {
      font-size: 0.68rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: var(--text-faint);
      background: var(--glass-bg);
    }
    .cmp-table td { color: var(--text-muted); }
    .cmp-table td:first-child { font-weight: 600; color: var(--text); }
    .cmp-table tr:hover td { background: rgba(255,255,255,0.025); }
    .cval  { color: var(--valterite) !important; }
    .caeth { color: var(--aetherite) !important; }
    .cerin { color: var(--erinium)   !important; }
  </style>
</head>
